---
/**
 * Branding page — Theme selector + logo + typography + usage guidelines + icons.
 * Artour picks his preferred color scheme here; it becomes the final brand direction.
 * Accessible only via direct link (not in navigation).
 */
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import '../styles/components.css';
import '../styles/animations.css';

import Navigation from '../components/Navigation.astro';
import PageHero from '../components/PageHero.astro';
import GoldDivider from '../components/GoldDivider.astro';
import PageFooter from '../components/PageFooter.astro';
import SubpageScripts from '../components/SubpageScripts.astro';

import ThemeSelector from '../components/brand/ThemeSelector.astro';
import LogoShowcase from '../components/brand/LogoShowcase.astro';
import ColorPalette from '../components/brand/ColorPalette.astro';
import Typography from '../components/brand/Typography.astro';
import UsageGuidelines from '../components/brand/UsageGuidelines.astro';
import Iconography from '../components/brand/Iconography.astro';
---

<Layout title="Branding & Color Themes — Algosphere Asset Management" description="Choose the brand color direction for Algosphere Asset Management.">

  <Navigation />

  <PageHero
    title="Brand Direction"
    subtitle="Choose the color palette that defines Algosphere. Each theme is engineered for wealth management: contrast, legibility, and gravitas. Pick one — it becomes the brand."
    label="Color & Identity"
  />

  <GoldDivider />
  <ThemeSelector />

  <LogoShowcase />
  <GoldDivider />

  <ColorPalette />
  <GoldDivider />

  <Typography />
  <GoldDivider />

  <UsageGuidelines />
  <GoldDivider />

  <Iconography />

  <PageFooter />

</Layout>

<SubpageScripts />

<!-- Branding theme switcher (card selection + live preview updates) -->
<script>
  import '../scripts/branding-switcher';
</script>

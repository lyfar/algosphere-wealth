<!-- Theme Switcher Script -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const pills = document.querySelectorAll<HTMLButtonElement>('.theme-pill');
    const descEl = document.getElementById('theme-desc');

    // Theme descriptions (must match server order)
    const descriptions: Record<string, string> = {
      'gold-classic': 'Timeless. The original palette of old-world finance.',
      'deep-navy': 'Trust. The confidence of institutional banking.',
      'emerald': 'Growth. Prosperity with measured restraint.',
      'burgundy': 'Heritage. Armenian warmth meets financial authority.',
      'platinum': 'Precision. Monochromatic clarity for modern wealth.',
      'sapphire': 'Regal. The crown jewels of investment management.',
    };

    function hexToHSL(hex: string): { h: number; s: number; l: number } {
      let r = parseInt(hex.slice(1, 3), 16) / 255;
      let g = parseInt(hex.slice(3, 5), 16) / 255;
      let b = parseInt(hex.slice(5, 7), 16) / 255;
      const max = Math.max(r, g, b), min = Math.min(r, g, b);
      let h = 0, s = 0;
      const l = (max + min) / 2;
      if (max !== min) {
        const d = max - min;
        s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
        switch (max) {
          case r: h = ((g - b) / d + (g < b ? 6 : 0)) / 6; break;
          case g: h = ((b - r) / d + 2) / 6; break;
          case b: h = ((r - g) / d + 4) / 6; break;
        }
      }
      return { h: h * 360, s: s * 100, l: l * 100 };
    }

    function applyTheme(btn: HTMLButtonElement) {
      const id = btn.dataset.theme!;
      const accent = btn.dataset.accent!;
      const accentLight = btn.dataset.accentLight!;
      const accentDark = btn.dataset.accentDark!;
      const bgDark = btn.dataset.bgDark!;
      const bgLight = btn.dataset.bgLight!;
      const textOnDark = btn.dataset.textOnDark!;
      const textOnLight = btn.dataset.textOnLight!;
      const secondary = btn.dataset.secondary!;

      // Update pills
      pills.forEach(p => {
        if (p === btn) {
          p.className = 'theme-pill px-5 py-2.5 rounded-full text-[0.72rem] tracking-[0.12em] uppercase font-medium transition-all duration-400 border cursor-pointer';
          p.style.borderColor = accent + '66';
          p.style.color = accent;
          p.style.background = accent + '14';
        } else {
          p.className = 'theme-pill px-5 py-2.5 rounded-full text-[0.72rem] tracking-[0.12em] uppercase font-medium transition-all duration-400 border cursor-pointer border-glass-border text-card-body-muted hover:text-text-primary bg-transparent';
          p.style.borderColor = '';
          p.style.color = '';
          p.style.background = '';
        }
      });

      // Description
      if (descEl) descEl.textContent = descriptions[id] || '';

      // Logo backgrounds
      const logoDark = document.getElementById('logo-dark-bg');
      const logoLight = document.getElementById('logo-light-bg');
      const logoH = document.getElementById('logo-h-lockup');
      const logoV = document.getElementById('logo-v-lockup');

      if (logoDark) logoDark.style.background = bgDark;
      if (logoLight) logoLight.style.background = bgLight;
      if (logoH) logoH.style.background = bgDark;
      if (logoV) logoV.style.background = bgDark;

      // Logo SVG recolor via CSS filter: approximate hue rotation
      // For the "On Dark" logos, tint toward accent color
      const accentHSL = hexToHSL(accent);
      const goldHSL = hexToHSL('#D4AF37');
      const hueShift = accentHSL.h - goldHSL.h;
      const satRatio = accentHSL.s / Math.max(goldHSL.s, 1);

      document.querySelectorAll<HTMLElement>('.logo-recolor').forEach(el => {
        if (id === 'gold-classic') {
          el.style.filter = '';
        } else {
          el.style.filter = `hue-rotate(${hueShift}deg) saturate(${satRatio.toFixed(2)})`;
        }
      });

      // Lockup text colors
      document.querySelectorAll<HTMLElement>('.lockup-title').forEach(el => {
        el.style.color = textOnDark;
      });
      document.querySelectorAll<HTMLElement>('.lockup-sub').forEach(el => {
        el.style.color = accent;
      });

      // Palette swatches
      const setS = (elId: string, color: string) => {
        const el = document.getElementById(elId);
        if (el) el.style.background = color;
        const hexEl = document.getElementById(elId + '-hex');
        if (hexEl) {
          hexEl.textContent = color.toUpperCase();
          hexEl.style.color = accent;
        }
      };
      setS('swatch-accent', accent);
      setS('swatch-accent-light', accentLight);
      setS('swatch-accent-dark', accentDark);
      setS('swatch-bg-dark', bgDark);
      setS('swatch-bg-light', bgLight);
      setS('swatch-secondary', secondary);

      // Combination previews
      const combos: Record<string, { bg: string; text: string }> = {
        'combo-accent-dark': { bg: bgDark, text: accent },
        'combo-text-dark': { bg: bgDark, text: textOnDark },
        'combo-text-light': { bg: bgLight, text: textOnLight },
        'combo-accent-secondary': { bg: secondary, text: accentLight },
        'combo-secondary-dark': { bg: bgDark, text: secondary },
        'combo-hero': { bg: bgDark, text: textOnDark },
      };

      for (const [elId, colors] of Object.entries(combos)) {
        const card = document.getElementById(elId);
        if (!card) continue;
        card.style.background = colors.bg;
        const textEls = card.querySelectorAll<HTMLElement>('.combo-text-accent, .combo-text-primary, .combo-text-on-light, .combo-text-accent-light, .combo-text-secondary');
        // Set per-class
        card.querySelectorAll<HTMLElement>('.combo-text-accent').forEach(el => { el.style.color = accent; });
        card.querySelectorAll<HTMLElement>('.combo-text-primary').forEach(el => { el.style.color = textOnDark; });
        card.querySelectorAll<HTMLElement>('.combo-text-on-light').forEach(el => { el.style.color = textOnLight; });
        card.querySelectorAll<HTMLElement>('.combo-text-accent-light').forEach(el => { el.style.color = accentLight; });
        card.querySelectorAll<HTMLElement>('.combo-text-secondary').forEach(el => { el.style.color = secondary; });
      }

      // Section accent lines
      document.querySelectorAll<HTMLElement>('.section-accent').forEach(el => {
        el.style.background = `linear-gradient(90deg, ${accent}, ${accent}26)`;
      });

      // Typography accent labels
      document.querySelectorAll<HTMLElement>('.typo-accent').forEach(el => {
        el.style.color = accent + 'D9';
      });

      // Guideline icon colors
      document.querySelectorAll<HTMLElement>('.guideline-icon').forEach(el => {
        el.style.color = accent + 'D9';
      });
      document.querySelectorAll<HTMLElement>('.guideline-strong').forEach(el => {
        el.style.color = accent + 'D9';
      });
      document.querySelectorAll<HTMLElement>('.guideline-bullet').forEach(el => {
        el.style.color = accent + 'D9';
      });

      // Do card border
      document.querySelectorAll<HTMLElement>('.do-card').forEach(el => {
        el.style.borderLeftColor = accent + '66';
      });
    }

    pills.forEach(pill => {
      pill.addEventListener('click', () => applyTheme(pill));
    });
  });
</script>

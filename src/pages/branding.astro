---
/**
 * Branding page — Theme selector + approved logo + typography + usage guidelines.
 * Artour picks his preferred color scheme here; it becomes the final brand direction.
 * Accessible only via direct link (not in navigation).
 */
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import '../styles/components.css';
import '../styles/animations.css';

import Navigation from '../components/Navigation.astro';
import PageHero from '../components/PageHero.astro';
import GoldDivider from '../components/GoldDivider.astro';
import PageFooter from '../components/PageFooter.astro';
import SubpageScripts from '../components/SubpageScripts.astro';

// Import themes from shared module (server-side for template rendering)
import { THEMES } from '../scripts/theme';
const themes = THEMES;
---

<Layout title="Branding & Color Themes — Algosphere Asset Management" description="Choose the brand color direction for Algosphere Asset Management.">

  <Navigation />

  <PageHero
    title="Brand Direction"
    subtitle="Choose the color palette that defines Algosphere. Each theme is engineered for wealth management: contrast, legibility, and gravitas. Pick one — it becomes the brand."
    label="Color & Identity"
  />

  <GoldDivider />

  <!-- ═══════════════════════════════════════════
       SECTION 1: THEME SELECTOR (cards with rationale)
       ═══════════════════════════════════════════ -->
  <section class="relative py-16 sm:py-20 overflow-hidden">
    <div class="section-inner max-w-[1200px] mx-auto px-6 lg:px-20 relative z-10">

      <!-- Theme cards grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" id="theme-cards">
        {themes.map((t) => (
          <button
            class="theme-card group rounded-2xl border border-glass-border p-6 text-left transition-all duration-400 cursor-pointer hover:border-glass-border/60"
            data-theme={t.id}
            data-accent={t.accent}
            data-accent-light={t.accentLight}
            data-accent-dark={t.accentDark}
            data-bg-dark={t.bgDark}
            data-bg-light={t.bgLight}
            data-text-on-dark={t.textOnDark}
            data-text-on-light={t.textOnLight}
            data-secondary={t.secondary}
          >
            <!-- Color bar -->
            <div class="flex gap-1.5 mb-4">
              <span class="h-2 flex-1 rounded-full" style={`background: ${t.accent};`}></span>
              <span class="h-2 w-8 rounded-full" style={`background: ${t.accentLight}; opacity: 0.7;`}></span>
              <span class="h-2 w-5 rounded-full" style={`background: ${t.secondary}; opacity: 0.5;`}></span>
            </div>
            <!-- Name -->
            <p class="font-heading text-lg font-semibold text-text-primary mb-1 theme-card-name">{t.name}</p>
            <!-- Tagline -->
            <p class="text-[0.78rem] text-card-body font-light leading-[1.6] theme-card-desc">{t.desc}</p>
          </button>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SECTION 2: LOGO SHOWCASE (single approved logo)
       ═══════════════════════════════════════════ -->
  <section class="relative py-16 sm:py-24 overflow-hidden" id="logo-showcase">
    <div class="absolute top-0 left-0 w-[500px] h-[500px] ambient-blob bg-gold-400"></div>

    <div class="section-inner max-w-[1200px] mx-auto px-6 lg:px-20 relative z-10">

      <div class="gs-reveal mb-6">
        <div class="section-accent" id="accent-line-1"></div>
        <p class="section-label">Logo Mark</p>
      </div>

      <div class="gs-reveal mt-8 mb-12">
        <p class="text-[17px] text-card-body font-light leading-[1.75] max-w-[720px]">
          The approved Algosphere mark in four standard contexts. When you switch themes above, the accent color updates across all lockups.
        </p>
      </div>

      <!-- 4-up logo grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">

        <!-- On Dark -->
        <div class="gs-reveal-scale rounded-2xl border border-glass-border p-8 flex flex-col items-center justify-center min-h-[220px] transition-all duration-500"
             id="logo-dark-bg" style="background: #0A0A0A;">
          <img src="/logo-mark.svg" alt="Algosphere mark" class="h-16 w-auto" />
          <p class="mt-4 text-[0.6rem] tracking-[0.12em] uppercase logo-label-dark" style="color: rgba(255,255,255,0.35);">On Dark</p>
        </div>

        <!-- On Light -->
        <div class="gs-reveal-scale rounded-2xl border border-gray-200 p-8 flex flex-col items-center justify-center min-h-[220px] transition-all duration-500"
             id="logo-light-bg" style="background: #FFFFFF;">
          <img src="/logo-mark.svg" alt="Algosphere mark" class="h-16 w-auto" />
          <p class="mt-4 text-[0.6rem] tracking-[0.12em] uppercase" style="color: #999;">On Light</p>
        </div>

        <!-- Horizontal Lockup -->
        <div class="gs-reveal-scale rounded-2xl border border-glass-border p-8 flex flex-col items-center justify-center min-h-[220px] transition-all duration-500"
             id="logo-h-lockup" style="background: #0A0A0A;">
          <div class="flex items-center gap-4">
            <img src="/logo-mark.svg" alt="" class="h-10 w-auto" />
            <div class="flex flex-col">
              <span class="text-[0.85rem] tracking-[0.22em] uppercase font-semibold leading-tight lockup-title" style="color: #F5F5F5; font-family: 'Cormorant Garamond', serif;">Algosphere</span>
              <span class="text-[0.42rem] tracking-[0.28em] uppercase leading-tight mt-0.5 lockup-sub" style="color: #D4AF37;">Asset Management</span>
            </div>
          </div>
          <p class="mt-4 text-[0.6rem] tracking-[0.12em] uppercase logo-label-dark" style="color: rgba(255,255,255,0.35);">Horizontal</p>
        </div>

        <!-- Vertical Lockup -->
        <div class="gs-reveal-scale rounded-2xl border border-glass-border p-8 flex flex-col items-center justify-center min-h-[220px] transition-all duration-500"
             id="logo-v-lockup" style="background: #0A0A0A;">
          <div class="flex flex-col items-center gap-3">
            <img src="/logo-mark.svg" alt="" class="h-12 w-auto" />
            <div class="flex flex-col items-center">
              <span class="text-[0.8rem] tracking-[0.22em] uppercase font-semibold leading-tight lockup-title" style="color: #F5F5F5; font-family: 'Cormorant Garamond', serif;">Algosphere</span>
              <span class="text-[0.4rem] tracking-[0.28em] uppercase leading-tight mt-1 lockup-sub" style="color: #D4AF37;">Asset Management</span>
            </div>
          </div>
          <p class="mt-4 text-[0.6rem] tracking-[0.12em] uppercase logo-label-dark" style="color: rgba(255,255,255,0.35);">Vertical</p>
        </div>

      </div>
    </div>
  </section>

  <GoldDivider />

  <!-- ═══════════════════════════════════════════
       SECTION 3: COLOR PALETTE (dynamic)
       ═══════════════════════════════════════════ -->
  <section class="relative py-24 sm:py-32 overflow-hidden" id="palette-section">
    <div class="absolute top-1/2 right-0 w-[500px] h-[500px] ambient-blob bg-burgundy-400"></div>

    <div class="section-inner max-w-[1200px] mx-auto px-6 lg:px-20 relative z-10">

      <div class="gs-reveal mb-6">
        <div class="section-accent" id="accent-line-2"></div>
        <p class="section-label">Color Palette</p>
      </div>

      <div class="gs-reveal mt-8 mb-16">
        <p class="text-[17px] text-card-body font-light leading-[1.75] max-w-[720px]">
          The active palette for this theme. Primary accent drives headlines, CTAs, and brand moments. Supporting tones handle backgrounds, borders, and depth.
        </p>
      </div>

      <!-- Palette swatches (6 swatches, dynamically colored) -->
      <div class="grid sm:grid-cols-3 lg:grid-cols-6 gap-5" id="palette-swatches">
        <div class="gs-reveal-scale">
          <div class="h-24 rounded-2xl border border-glass-border transition-all duration-500" id="swatch-accent" style="background: #D4AF37;"></div>
          <p class="mt-3 text-[0.72rem] tracking-[0.14em] uppercase text-card-body-muted font-medium">Accent</p>
          <p class="mt-1 font-mono text-[0.78rem] text-gold-accent" id="swatch-accent-hex">#D4AF37</p>
        </div>
        <div class="gs-reveal-scale">
          <div class="h-24 rounded-2xl border border-glass-border transition-all duration-500" id="swatch-accent-light" style="background: #F0D78C;"></div>
          <p class="mt-3 text-[0.72rem] tracking-[0.14em] uppercase text-card-body-muted font-medium">Light</p>
          <p class="mt-1 font-mono text-[0.78rem] text-gold-accent" id="swatch-accent-light-hex">#F0D78C</p>
        </div>
        <div class="gs-reveal-scale">
          <div class="h-24 rounded-2xl border border-glass-border transition-all duration-500" id="swatch-accent-dark" style="background: #A48111;"></div>
          <p class="mt-3 text-[0.72rem] tracking-[0.14em] uppercase text-card-body-muted font-medium">Dark</p>
          <p class="mt-1 font-mono text-[0.78rem] text-gold-accent" id="swatch-accent-dark-hex">#A48111</p>
        </div>
        <div class="gs-reveal-scale">
          <div class="h-24 rounded-2xl border border-glass-border transition-all duration-500" id="swatch-bg-dark" style="background: #0A0A0A;"></div>
          <p class="mt-3 text-[0.72rem] tracking-[0.14em] uppercase text-card-body-muted font-medium">Background</p>
          <p class="mt-1 font-mono text-[0.78rem] text-gold-accent" id="swatch-bg-dark-hex">#0A0A0A</p>
        </div>
        <div class="gs-reveal-scale">
          <div class="h-24 rounded-2xl border border-glass-border transition-all duration-500" id="swatch-bg-light" style="background: #F5F0E8;"></div>
          <p class="mt-3 text-[0.72rem] tracking-[0.14em] uppercase text-card-body-muted font-medium">Light BG</p>
          <p class="mt-1 font-mono text-[0.78rem] text-gold-accent" id="swatch-bg-light-hex">#F5F0E8</p>
        </div>
        <div class="gs-reveal-scale">
          <div class="h-24 rounded-2xl border border-glass-border transition-all duration-500" id="swatch-secondary" style="background: #722F37;"></div>
          <p class="mt-3 text-[0.72rem] tracking-[0.14em] uppercase text-card-body-muted font-medium">Secondary</p>
          <p class="mt-1 font-mono text-[0.78rem] text-gold-accent" id="swatch-secondary-hex">#722F37</p>
        </div>
      </div>

      <!-- Live Combination Preview -->
      <div class="mt-16">
        <h3 class="gs-reveal font-heading text-2xl text-text-primary font-semibold mb-8">Live Combinations</h3>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" id="combo-grid">
          <!-- Accent on Dark -->
          <div class="gs-reveal-scale combo-card rounded-2xl border border-glass-border p-8 flex flex-col items-center justify-center min-h-[140px] transition-all duration-500" id="combo-accent-dark" style="background: #0A0A0A;">
            <span class="font-heading text-3xl font-semibold combo-text-accent" style="color: #D4AF37;">Algosphere</span>
            <p class="mt-2 text-[0.6rem] tracking-[0.12em] uppercase combo-label-on-dark">Accent on Dark</p>
          </div>
          <!-- Text on Dark -->
          <div class="gs-reveal-scale combo-card rounded-2xl border border-glass-border p-8 flex flex-col items-center justify-center min-h-[140px] transition-all duration-500" id="combo-text-dark" style="background: #0A0A0A;">
            <span class="font-heading text-3xl font-semibold combo-text-primary" style="color: #F5F5F5;">Algosphere</span>
            <p class="mt-2 text-[0.6rem] tracking-[0.12em] uppercase combo-label-on-dark">Text on Dark</p>
          </div>
          <!-- Text on Light -->
          <div class="gs-reveal-scale combo-card rounded-2xl border border-gray-200 p-8 flex flex-col items-center justify-center min-h-[140px] transition-all duration-500" id="combo-text-light" style="background: #FFFFFF;">
            <span class="font-heading text-3xl font-semibold combo-text-on-light" style="color: #0A0A0A;">Algosphere</span>
            <p class="mt-2 text-[0.6rem] tracking-[0.12em] uppercase combo-label-on-light">Text on Light</p>
          </div>
          <!-- Accent on Secondary -->
          <div class="gs-reveal-scale combo-card rounded-2xl border border-glass-border p-8 flex flex-col items-center justify-center min-h-[140px] transition-all duration-500" id="combo-accent-secondary" style="background: #722F37;">
            <span class="font-heading text-3xl font-semibold combo-text-accent-light" style="color: #F0D78C;">Algosphere</span>
            <p class="mt-2 text-[0.6rem] tracking-[0.12em] uppercase combo-label-on-dark">Accent on Secondary</p>
          </div>
          <!-- Secondary on Dark -->
          <div class="gs-reveal-scale combo-card rounded-2xl border border-glass-border p-8 flex flex-col items-center justify-center min-h-[140px] transition-all duration-500" id="combo-secondary-dark" style="background: #0A0A0A;">
            <span class="font-heading text-3xl font-semibold combo-text-secondary" style="color: #722F37;">Algosphere</span>
            <p class="mt-2 text-[0.6rem] tracking-[0.12em] uppercase combo-label-on-dark">Secondary on Dark</p>
          </div>
          <!-- Full hero preview -->
          <div class="gs-reveal-scale combo-card rounded-2xl border border-glass-border p-8 flex flex-col items-center justify-center min-h-[140px] transition-all duration-500" id="combo-hero" style="background: #0A0A0A;">
            <span class="text-[0.6rem] tracking-[0.2em] uppercase font-medium mb-1 combo-text-accent" style="color: #D4AF37;">Where Vision Meets</span>
            <span class="font-heading text-2xl font-semibold combo-text-primary" style="color: #F5F5F5;">Legacy</span>
            <p class="mt-2 text-[0.6rem] tracking-[0.12em] uppercase combo-label-on-dark">Hero Preview</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <GoldDivider />

  <!-- ═══════════════════════════════════════════
       SECTION 4: TYPOGRAPHY (unchanged)
       ═══════════════════════════════════════════ -->
  <section class="relative py-24 sm:py-32 overflow-hidden">
    <div class="absolute top-0 left-1/4 w-[400px] h-[400px] ambient-blob bg-gold-400"></div>

    <div class="section-inner max-w-[1200px] mx-auto px-6 lg:px-20 relative z-10">

      <div class="gs-reveal mb-6">
        <div class="section-accent" id="accent-line-3"></div>
        <p class="section-label">Typography</p>
      </div>

      <div class="gs-reveal mt-8 mb-16">
        <p class="text-[17px] text-card-body font-light leading-[1.75] max-w-[720px]">
          Typography is the voice of our brand. Two carefully selected typefaces balance classical elegance with modern precision.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-8">
        <!-- Heading Font -->
        <div class="gs-reveal glass-card p-10 lg:p-12">
          <p class="text-[0.68rem] tracking-[0.16em] uppercase font-medium mb-2 typo-accent" style="color: var(--color-gold-accent);">Heading</p>
          <h2 class="font-heading text-4xl sm:text-5xl text-text-primary font-semibold mb-4 leading-[1.08]">Cormorant Garamond</h2>
          <p class="text-[15px] text-card-body font-light leading-[1.75] mb-6">
            Classical serif with high-contrast strokes. Used for headlines, hero titles, and brand personality moments.
          </p>
          <div class="space-y-2 pt-6 border-t border-glass-border">
            <p class="font-heading text-xl text-text-primary" style="font-weight: 400;">Regular 400 — Where Vision Meets Legacy</p>
            <p class="font-heading text-xl text-text-primary" style="font-weight: 500;">Medium 500 — Where Vision Meets Legacy</p>
            <p class="font-heading text-xl text-text-primary" style="font-weight: 600;">Semibold 600 — Where Vision Meets Legacy</p>
          </div>
        </div>

        <!-- Body Font -->
        <div class="gs-reveal glass-card p-10 lg:p-12">
          <p class="text-[0.68rem] tracking-[0.16em] uppercase font-medium mb-2 typo-accent" style="color: var(--color-gold-accent);">Body</p>
          <h2 class="text-4xl sm:text-5xl text-text-primary font-semibold mb-4 leading-[1.08]" style="font-family: Inter, sans-serif;">Inter</h2>
          <p class="text-[15px] text-card-body font-light leading-[1.75] mb-6">
            Modern geometric sans-serif for screen legibility. Used for body text, UI elements, data displays, and legal.
          </p>
          <div class="space-y-2 pt-6 border-t border-glass-border">
            <p class="text-xl text-text-primary" style="font-weight: 300;">Light 300 — Closed-End Investment Fund</p>
            <p class="text-xl text-text-primary" style="font-weight: 400;">Regular 400 — Closed-End Investment Fund</p>
            <p class="text-xl text-text-primary" style="font-weight: 500;">Medium 500 — Closed-End Investment Fund</p>
            <p class="text-xl text-text-primary" style="font-weight: 600;">Semibold 600 — Closed-End Investment Fund</p>
          </div>
        </div>
      </div>

      <!-- Type Scale -->
      <div class="gs-reveal mt-12">
        <h3 class="font-heading text-2xl text-text-primary font-semibold mb-8">Type Scale</h3>
        <div class="glass-card p-10 lg:p-12 space-y-6">
          <div class="flex items-baseline gap-6 border-b border-glass-border pb-4">
            <span class="text-[0.6rem] font-mono text-card-body-muted w-12 shrink-0">4.5rem</span>
            <span class="font-heading text-[4.5rem] text-text-primary font-semibold leading-none">Aa</span>
          </div>
          <div class="flex items-baseline gap-6 border-b border-glass-border pb-4">
            <span class="text-[0.6rem] font-mono text-card-body-muted w-12 shrink-0">2.5rem</span>
            <span class="font-heading text-[2.5rem] text-text-primary font-semibold leading-tight">Section Heading</span>
          </div>
          <div class="flex items-baseline gap-6 border-b border-glass-border pb-4">
            <span class="text-[0.6rem] font-mono text-card-body-muted w-12 shrink-0">1.25rem</span>
            <span class="font-heading text-[1.25rem] text-text-primary font-semibold">Card Title</span>
          </div>
          <div class="flex items-baseline gap-6 border-b border-glass-border pb-4">
            <span class="text-[0.6rem] font-mono text-card-body-muted w-12 shrink-0">17px</span>
            <span class="text-[17px] text-card-body font-light">Body text — the core reading size for all paragraph content across the site.</span>
          </div>
          <div class="flex items-baseline gap-6">
            <span class="text-[0.6rem] font-mono text-card-body-muted w-12 shrink-0">0.75rem</span>
            <span class="text-[0.75rem] tracking-[0.16em] uppercase text-card-body-muted font-medium">Section Label · Caption</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <GoldDivider />

  <!-- ═══════════════════════════════════════════
       SECTION 5: USAGE GUIDELINES
       ═══════════════════════════════════════════ -->
  <section class="relative py-24 sm:py-32 overflow-hidden">
    <div class="absolute bottom-0 right-1/3 w-[500px] h-[500px] ambient-blob bg-navy-400"></div>

    <div class="section-inner max-w-[1200px] mx-auto px-6 lg:px-20 relative z-10">

      <div class="gs-reveal mb-6">
        <div class="section-accent" id="accent-line-4"></div>
        <p class="section-label">Usage Guidelines</p>
      </div>

      <div class="gs-reveal mt-8 mb-16">
        <p class="text-[17px] text-card-body font-light leading-[1.75] max-w-[720px]">
          Consistent application of our visual identity ensures brand recognition and trust. Follow these guidelines to maintain the integrity of the Algosphere mark.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-8 lg:gap-10">

        <!-- Clear Space -->
        <div class="gs-reveal-scale">
          <div class="glass-card p-10 lg:p-12 h-full">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 border border-glass-border rounded-xl flex items-center justify-center bg-gold-400/[0.03]">
                <svg class="w-5 h-5 guideline-icon" style="color: var(--color-gold-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 9V4.5M9 9H4.5M9 9L3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9h4.5M15 9V4.5M15 9l5.25-5.25M15 15h4.5M15 15v4.5m0-4.5l5.25 5.25" />
                </svg>
              </div>
              <h3 class="font-heading text-xl text-card-title font-semibold">Clear Space</h3>
            </div>
            <p class="text-[16px] text-card-body font-light leading-[1.75]">
              Maintain a minimum clear space equal to <strong class="guideline-strong" style="color: var(--color-gold-accent);">½ the mark width</strong> on all sides. The logo must breathe.
            </p>
          </div>
        </div>

        <!-- Minimum Size -->
        <div class="gs-reveal-scale">
          <div class="glass-card p-10 lg:p-12 h-full">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 border border-glass-border rounded-xl flex items-center justify-center bg-gold-400/[0.03]">
                <svg class="w-5 h-5 guideline-icon" style="color: var(--color-gold-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
                </svg>
              </div>
              <h3 class="font-heading text-xl text-card-title font-semibold">Minimum Size</h3>
            </div>
            <p class="text-[16px] text-card-body font-light leading-[1.75]">
              <strong class="guideline-strong" style="color: var(--color-gold-accent);">Digital:</strong> 32×32px (mark only), 120px wide (horizontal lockup)<br/>
              <strong class="guideline-strong" style="color: var(--color-gold-accent);">Print:</strong> 12mm (mark only), 40mm wide (horizontal lockup)
            </p>
          </div>
        </div>

        <!-- Do -->
        <div class="gs-reveal-scale">
          <div class="glass-card p-10 lg:p-12 h-full do-card" style="border-left: 2px solid var(--color-gold-soft);">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 border border-glass-border rounded-xl flex items-center justify-center bg-gold-400/[0.03]">
                <svg class="w-5 h-5 guideline-icon" style="color: var(--color-gold-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="font-heading text-xl text-card-title font-semibold">Do</h3>
            </div>
            <ul class="space-y-3 text-[16px] text-card-body font-light leading-[1.75]">
              <li class="flex items-start gap-2"><span class="guideline-bullet mt-1" style="color: var(--color-gold-accent);">•</span><span>Use only approved colour combinations</span></li>
              <li class="flex items-start gap-2"><span class="guideline-bullet mt-1" style="color: var(--color-gold-accent);">•</span><span>Maintain aspect ratio — always scale uniformly</span></li>

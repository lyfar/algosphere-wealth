---
/**
 * Home page — cinematic hero + key metrics + value prop cards + insights teaser + CTA.
 * Phase 2: Content & Design Polish
 */
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import '../styles/components.css';
import '../styles/animations.css';

import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import GoldDivider from '../components/GoldDivider.astro';
import PageFooter from '../components/PageFooter.astro';

import MetricsBar from '../components/home/MetricsBar.astro';
import AboutTeaser from '../components/home/AboutTeaser.astro';
import WhyAlgosphere from '../components/home/WhyAlgosphere.astro';
import HomeCTA from '../components/home/HomeCTA.astro';
---

<Layout title="Algosphere Asset Management">

  <Navigation />

  <Hero />

  <MetricsBar />

  <GoldDivider />

  <AboutTeaser />

  <GoldDivider />

  <WhyAlgosphere />

  <GoldDivider />

  <HomeCTA />

  <GoldDivider />

  <PageFooter />

  <!-- Main script -->
  <script>
    import { initLenis, animateHero, initParallax, initScrollAnimations } from '../scripts/animations';
    import { initCustomCursor } from '../scripts/cursor';
    import { createStarfield, initParticles } from '../scripts/particles';
    import { initNavbar, initMobileMenu } from '../scripts/navigation';
    import { switchLanguage, initLanguageSwitcher } from '../scripts/language';
    import { initTheme } from '../scripts/theme';

    document.addEventListener('DOMContentLoaded', () => {
      initTheme(); // Apply saved theme from branding page
      createStarfield();
      initParticles();
      initLenis();
      initCustomCursor();
      initNavbar();
      initMobileMenu(switchLanguage);
      initLanguageSwitcher();
      animateHero();
      initParallax();
      initScrollAnimations();
    });
  </script>

</Layout>

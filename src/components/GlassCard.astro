---
/**
 * Reusable glass card with icon, title, and body content.
 */
interface Props {
  title: string;
  titleHy?: string;
  titleRu?: string;
  titleFr?: string;
  titleAr?: string;
  iconPath: string;
  /** Additional SVG path (some icons have 2) */
  iconPath2?: string;
  class?: string;
}

const { title, titleHy, titleRu, titleFr, titleAr, iconPath, iconPath2, class: className = '' } = Astro.props;
---

<div class:list={['glass-card p-7 lg:p-8 gs-reveal-scale', className]}>
  <div class="flex items-start gap-4 mb-4">
    <div class="w-10 h-10 shrink-0 border border-glass-border rounded-xl flex items-center justify-center bg-gold-400/[0.06]">
      <svg class="w-5 h-5 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
        {iconPath2 && <path stroke-linecap="round" stroke-linejoin="round" d={iconPath2} />}
      </svg>
    </div>
    <h3
      class="font-heading text-lg text-card-title font-semibold leading-snug pt-1.5"
      data-i18n
      data-hy={titleHy || title}
      data-en={title}
      data-ru={titleRu || title}
      data-fr={titleFr || title}
      data-ar={titleAr || title}
    >
      {titleHy || title}
    </h3>
  </div>
  <slot />
</div>

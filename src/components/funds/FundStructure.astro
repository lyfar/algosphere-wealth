---
// Fund Structure Overview
import SectionHeader from '../SectionHeader.astro';
---
<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
    <div class="absolute top-0 left-0 w-[500px] h-[500px] ambient-blob bg-gold-400"></div>

    <div class="section-inner max-w-[1200px] mx-auto px-6 lg:px-20 relative z-10">
      <SectionHeader label="Fund Structure" labelHy="&#1366;&#1400;&#1398;&#1380;&#1387; &#1343;&#1377;&#1404;&#1400;&#1410;&#1409;&#1406;&#1377;&#1390;&#1412;" />

      <h2 class="gs-reveal font-heading text-2xl sm:text-3xl lg:text-4xl text-text-primary font-semibold mb-12 leading-[1.15] mt-6">
        <span data-i18n data-hy="&#1363;&#1377;&#1391;, &#1400;&#1401; &#1392;&#1408;&#1377;&#1402;&#1377;&#1408;&#1377;&#1391;&#1377;&#1397;&#1387;&#1398; &#1398;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;&#1377;&#1397;&#1387;&#1398; <span class='text-gold-gradient'>&#1366;&#1400;&#1398;&#1380;&#1381;&#1408;</span>" data-en="Closed-End, Non-Public <span class='text-gold-gradient'>Investment Funds</span>">Closed-End, Non-Public <span class="text-gold-gradient">Investment Funds</span></span>
      </h2>

      <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
        <div class="gs-reveal space-y-6 text-[16px] text-card-body font-light leading-[1.8]">
          <p data-i18n
             data-hy="Algosphere-&#1387; &#1411;&#1400;&#1398;&#1380;&#1381;&#1408;&#1384; &#1391;&#1377;&#1404;&#1400;&#1410;&#1409;&#1406;&#1377;&#1390; &#1381;&#1398; &#1400;&#1408;&#1402;&#1381;&#1405; &#1411;&#1377;&#1391;, &#1400;&#1401; &#1392;&#1408;&#1377;&#1402;&#1377;&#1408;&#1377;&#1391;&#1377;&#1397;&#1387;&#1398; &#1398;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;&#1377;&#1397;&#1387;&#1398; &#1411;&#1400;&#1398;&#1380;&#1381;&#1408;&#1417;"
             data-en="Algosphere's funds are structured as closed-end, non-public investment funds under Armenian law and regulated by the Central Bank of Armenia. This structure provides several key advantages for our investors:">
            Algosphere's funds are structured as closed-end, non-public investment funds under Armenian law and regulated by the Central Bank of Armenia. This structure provides several key advantages for our investors:
          </p>
          <ul class="space-y-3 ml-6">
            <li class="flex items-start gap-3">
              <span class="text-gold-400/60 mt-1.5">&#9670;</span>
              <span data-i18n data-hy="&#1333;&#1408;&#1391;&#1377;&#1408;&#1377;&#1386;&#1377;&#1396;&#1391;&#1381;&#1407; &#1398;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;&#1377;&#1397;&#1387;&#1398; &#1392;&#1400;&#1408;&#1387;&#1382;&#1400;&#1398;" data-en="Long-term investment horizon allowing patient capital deployment">Long-term investment horizon allowing patient capital deployment</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-gold-400/60 mt-1.5">&#9670;</span>
              <span data-i18n data-hy="&#1354;&#1408;&#1400;&#1414;&#1381;&#1405;&#1387;&#1400;&#1398;&#1377;&#1388; &#1391;&#1377;&#1404;&#1377;&#1406;&#1377;&#1408;&#1400;&#1410;&#1396;" data-en="Professional fund administration and independent custody">Professional fund administration and independent custody</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-gold-400/60 mt-1.5">&#9670;</span>
              <span data-i18n data-hy="&#1343;&#1377;&#1398;&#1400;&#1398;&#1377;&#1406;&#1400;&#1408; &#1392;&#1377;&#1399;&#1406;&#1381;&#1407;&#1406;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;&#1398;&#1381;&#1408;" data-en="Regular reporting and full regulatory compliance">Regular reporting and full regulatory compliance</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-gold-400/60 mt-1.5">&#9670;</span>
              <span data-i18n data-hy="&#1344;&#1377;&#1408;&#1391;&#1377;&#1397;&#1387;&#1398; &#1377;&#1408;&#1407;&#1400;&#1398;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;&#1398;&#1381;&#1408;" data-en="Tax efficiency under Armenian investment fund legislation">Tax efficiency under Armenian investment fund legislation</span>
            </li>
          </ul>
        </div>

        <div class="gs-reveal-right">
          <div class="glass-card p-8 lg:p-10">
            <h3 class="font-heading text-xl text-card-title font-semibold mb-6" data-i18n data-hy="&#1366;&#1400;&#1398;&#1380;&#1387; &#1359;&#1381;&#1394;&#1381;&#1391;&#1377;&#1407;&#1406;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;" data-en="Fund Highlights">Fund Highlights</h3>
            <div class="space-y-5">
              <div class="flex justify-between items-center py-3 border-b border-white/[0.06]">
                <span class="text-card-body-muted text-[14px] font-light" data-i18n data-hy="&#1366;&#1400;&#1398;&#1380;&#1387; &#1359;&#1381;&#1405;&#1377;&#1391;" data-en="Fund Type">Fund Type</span>
                <span class="text-text-primary text-[14px] font-medium" data-i18n data-hy="&#1363;&#1377;&#1391;, &#1400;&#1401; &#1392;&#1408;&#1377;&#1402;&#1377;&#1408;&#1377;&#1391;&#1377;&#1397;&#1387;&#1398;" data-en="Closed-end, Non-public">Closed-end, Non-public</span>
              </div>
              <div class="flex justify-between items-center py-3 border-b border-white/[0.06]">
                <span class="text-card-body-muted text-[14px] font-light" data-i18n data-hy="&#1343;&#1377;&#1408;&#1379;&#1377;&#1406;&#1400;&#1408;&#1387;&#1401;" data-en="Regulator">Regulator</span>
                <span class="text-text-primary text-[14px] font-medium" data-i18n data-hy="&#1344;&#1344; &#1343;&#1381;&#1398;&#1407;&#1408;&#1400;&#1398;&#1377;&#1391;&#1377;&#1398; &#1330;&#1377;&#1398;&#1391;" data-en="Central Bank of Armenia">Central Bank of Armenia</span>
              </div>
              <div class="flex justify-between items-center py-3 border-b border-white/[0.06]">
                <span class="text-card-body-muted text-[14px] font-light" data-i18n data-hy="&#1337;&#1387;&#1408;&#1377;&#1397;&#1387;&#1398; &#1350;&#1381;&#1408;&#1380;&#1408;&#1400;&#1394;&#1398;&#1381;&#1408;" data-en="Target Investors">Target Investors</span>
                <span class="text-text-primary text-[14px] font-medium" data-i18n data-hy="&#1352;&#1408;&#1377;&#1391;&#1377;&#1406;&#1400;&#1408;&#1406;&#1377;&#1390; &#1398;&#1381;&#1408;&#1380;&#1408;&#1400;&#1394;&#1398;&#1381;&#1408;" data-en="Qualified Investors">Qualified Investors</span>
              </div>
              <div class="flex justify-between items-center py-3 border-b border-white/[0.06]">
                <span class="text-card-body-muted text-[14px] font-light" data-i18n data-hy="&#1329;&#1400;&#1410;&#1380;&#1387;&#1407;&#1400;&#1408;" data-en="Auditor">Auditor</span>
                <span class="text-text-primary text-[14px] font-medium" data-i18n data-hy="&#1329;&#1398;&#1391;&#1377;&#1389; &#1381;&#1408;&#1408;&#1400;&#1408;&#1380; &#1391;&#1400;&#1394;&#1396;" data-en="Independent Third Party">Independent Third Party</span>
              </div>
              <div class="flex justify-between items-center py-3">
                <span class="text-card-body-muted text-[14px] font-light" data-i18n data-hy="&#1354;&#1377;&#1392;&#1377;&#1402;&#1377;&#1398;" data-en="Custodian">Custodian</span>
                <span class="text-text-primary text-[14px] font-medium" data-i18n data-hy="&#1329;&#1398;&#1391;&#1377;&#1389; &#1402;&#1377;&#1392;&#1377;&#1402;&#1377;&#1398;" data-en="Segregated Custody">Segregated Custody</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

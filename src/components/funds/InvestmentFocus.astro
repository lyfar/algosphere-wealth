---
// Investment Objectives & Focus
import SectionHeader from '../SectionHeader.astro';
---
<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] ambient-blob bg-gold-400"></div>

    <div class="section-inner max-w-[1200px] mx-auto px-6 lg:px-20 relative z-10">
      <div class="text-center mb-16">
        <SectionHeader label="Investment Focus" labelHy="&#1350;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;&#1377;&#1397;&#1387;&#1398; &#1352;&#1410;&#1394;&#1394;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;" centered>
          <h2 class="font-heading text-3xl sm:text-4xl lg:text-[3rem] text-text-primary font-semibold leading-[1.1]">
            <span data-i18n data-hy="&#1350;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;&#1377;&#1397;&#1387;&#1398; <span class='text-gold-gradient'>&#1350;&#1402;&#1377;&#1407;&#1377;&#1391;&#1398;&#1381;&#1408; &#1415; &#1329;&#1391;&#1407;&#1387;&#1406;&#1398;&#1381;&#1408;</span>" data-en="Objectives &amp; <span class='text-gold-gradient'>Target Assets</span>">Objectives &amp; <span class="text-gold-gradient">Target Assets</span></span>
          </h2>
        </SectionHeader>
      </div>

      <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
        <div class="gs-reveal-scale glass-card p-8">
          <div class="w-12 h-12 mb-6 border border-gold-400/25 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
            </svg>
          </div>
          <h3 class="font-heading text-xl text-card-title font-semibold mb-3" data-i18n data-hy="&#1339;&#1398;&#1406;&#1381;&#1405;&#1407;&#1387;&#1409;&#1387;&#1400;&#1398; &#1350;&#1402;&#1377;&#1407;&#1377;&#1391;&#1398;&#1381;&#1408;" data-en="Investment Objectives">Investment Objectives</h3>
          <p class="text-card-body-muted text-[14px] font-light leading-[1.75]" data-i18n
             data-hy="&#1333;&#1408;&#1391;&#1377;&#1408;&#1377;&#1386;&#1377;&#1396;&#1391;&#1381;&#1407; &#1391;&#1377;&#1402;&#1387;&#1407;&#1377;&#1388;&#1387; &#1377;&#1395;&#1387;&#1396; &#1415; &#1381;&#1391;&#1377;&#1396;&#1407;&#1377;&#1397;&#1387;&#1398; &#1377;&#1408;&#1407;&#1377;&#1380;&#1408;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;&#1417;"
             data-en="Long-term capital appreciation through disciplined deployment into Armenia's highest-conviction growth opportunities. We target risk-adjusted returns that meaningfully outperform traditional fixed-income alternatives while maintaining robust downside protection.">
            Long-term capital appreciation through disciplined deployment into Armenia's highest-conviction growth opportunities. We target risk-adjusted returns that meaningfully outperform traditional fixed-income alternatives while maintaining robust downside protection.
          </p>
        </div>

        <div class="gs-reveal-scale glass-card p-8">
          <div class="w-12 h-12 mb-6 border border-gold-400/25 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl text-card-title font-semibold mb-3" data-i18n data-hy="&#1337;&#1387;&#1408;&#1377;&#1397;&#1387;&#1398; &#1329;&#1391;&#1407;&#1387;&#1406;&#1398;&#1381;&#1408;" data-en="Target Asset Classes">Target Asset Classes</h3>
          <ul class="space-y-2 text-card-body-muted text-[14px] font-light leading-[1.75]">
            <li class="flex items-start gap-2">
              <span class="text-gold-400/60 mt-1.5">&#9670;</span>
              <span data-i18n data-hy="&#1359;&#1381;&#1389;&#1398;&#1400;&#1388;&#1400;&#1379;&#1387;&#1377; &#1415; &#1414;&#1387;&#1398;&#1407;&#1381;&#1412;" data-en="Technology &amp; Fintech">Technology &amp; Fintech</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-gold-400/60 mt-1.5">&#9670;</span>
              <span data-i18n data-hy="&#1329;&#1398;&#1399;&#1377;&#1408;&#1386; &#1379;&#1400;&#1410;&#1397;&#1412;" data-en="Real Estate &amp; Infrastructure">Real Estate &amp; Infrastructure</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-gold-400/60 mt-1.5">&#9670;</span>
              <span data-i18n data-hy="&#1343;&#1400;&#1408;&#1402;&#1400;&#1408;&#1377;&#1407;&#1387;&#1406; &#1402;&#1377;&#1408;&#1407;&#1377;&#1407;&#1400;&#1396;&#1405;&#1381;&#1408;" data-en="Corporate Bonds &amp; Fixed Income">Corporate Bonds &amp; Fixed Income</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-gold-400/60 mt-1.5">&#9670;</span>
              <span data-i18n data-hy="&#1348;&#1377;&#1405;&#1398;&#1377;&#1406;&#1400;&#1408; &#1391;&#1377;&#1402;&#1387;&#1407;&#1377;&#1388;" data-en="Private Equity &amp; Growth Capital">Private Equity &amp; Growth Capital</span>
            </li>
          </ul>
        </div>

        <div class="gs-reveal-scale glass-card p-8">
          <div class="w-12 h-12 mb-6 border border-gold-400/25 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3" />
            </svg>
          </div>
          <h3 class="font-heading text-xl text-card-title font-semibold mb-3" data-i18n data-hy="&#1329;&#1399;&#1389;&#1377;&#1408;&#1392;&#1377;&#1379;&#1408;&#1377;&#1391;&#1377;&#1398; &#1352;&#1410;&#1394;&#1394;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;" data-en="Geographic Focus">Geographic Focus</h3>
          <p class="text-card-body-muted text-[14px] font-light leading-[1.75]" data-i18n
             data-hy="&#1344;&#1377;&#1397;&#1377;&#1405;&#1407;&#1377;&#1398;&#1384; &#1415; &#1344;&#1377;&#1408;&#1377;&#1406;&#1377;&#1397;&#1387;&#1398; &#1343;&#1400;&#1406;&#1391;&#1377;&#1405;&#1387; &#1407;&#1377;&#1408;&#1377;&#1390;&#1377;&#1399;&#1408;&#1403;&#1377;&#1398;&#1384;&#1417;"
             data-en="Primary focus on Armenia, with selective exposure to the broader South Caucasus region. We leverage deep local networks, on-the-ground presence, and unique access to opportunities at the intersection of European, Russian, and Middle Eastern markets.">
            Primary focus on Armenia, with selective exposure to the broader South Caucasus region. We leverage deep local networks, on-the-ground presence, and unique access to opportunities at the intersection of European, Russian, and Middle Eastern markets.
          </p>
        </div>
      </div>
    </div>
  </section>

---
// Third-Party Service Providers / Independent Partners section
import SectionHeader from '../SectionHeader.astro';
---
<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
    <div class="absolute top-1/4 left-0 w-[400px] h-[400px] ambient-blob bg-gold-400"></div>

    <div class="section-inner max-w-[1200px] mx-auto px-6 lg:px-20 relative z-10">
      <div class="text-center mb-16">
        <SectionHeader label="Service Providers" labelHy="&#1342;&#1377;&#1404;&#1377;&#1397;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398; &#1348;&#1377;&#1407;&#1400;&#1410;&#1409;&#1400;&#1394;&#1398;&#1381;&#1408;" centered>
          <h2 class="font-heading text-3xl sm:text-4xl lg:text-[3rem] text-text-primary font-semibold leading-[1.1]">
            <span data-i18n data-hy="&#1329;&#1398;&#1391;&#1377;&#1389; <span class='text-gold-gradient'>&#1331;&#1400;&#1408;&#1390;&#1384;&#1398;&#1391;&#1381;&#1408;&#1398;&#1381;&#1408;</span>" data-en="Independent <span class='text-gold-gradient'>Partners</span>">Independent <span class="text-gold-gradient">Partners</span></span>
          </h2>
        </SectionHeader>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="gs-reveal-scale glass-card p-8 text-center">
          <div class="w-12 h-12 mx-auto mb-5 border border-gold-400/25 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="font-heading text-lg text-card-title font-semibold mb-2" data-i18n data-hy="&#1329;&#1400;&#1410;&#1380;&#1387;&#1407;&#1400;&#1408;" data-en="Auditor">Auditor</h3>
          <p class="text-gold-soft text-[14px] font-medium mb-2">Big4 Auditor</p>
          <p class="text-card-body-muted text-[13px] font-light leading-relaxed" data-i18n
             data-hy="&#1329;&#1398;&#1391;&#1377;&#1389; &#1377;&#1400;&#1410;&#1380;&#1387;&#1407;&#1400;&#1408;&#1377;&#1391;&#1377;&#1398; &#1405;&#1407;&#1400;&#1410;&#1379;&#1400;&#1410;&#1396;"
             data-en="Independent annual audit and financial statement review">Independent annual audit and financial statement review</p>
        </div>

        <div class="gs-reveal-scale glass-card p-8 text-center">
          <div class="w-12 h-12 mx-auto mb-5 border border-gold-400/25 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
            </svg>
          </div>
          <h3 class="font-heading text-lg text-card-title font-semibold mb-2" data-i18n data-hy="&#1354;&#1377;&#1392;&#1377;&#1402;&#1377;&#1398;" data-en="Custodian">Custodian</h3>
          <p class="text-gold-soft text-[14px] font-medium mb-2" data-i18n data-hy="&#1340;&#1387;&#1409;&#1381;&#1398;&#1382;&#1377;&#1406;&#1400;&#1408;&#1406;&#1377;&#1390; &#1354;&#1377;&#1392;&#1377;&#1402;&#1377;&#1398; &#1330;&#1377;&#1398;&#1391;" data-en="Licensed Custodian Bank">Licensed Custodian Bank</p>
          <p class="text-card-body-muted text-[13px] font-light leading-relaxed" data-i18n
             data-hy="&#1329;&#1391;&#1407;&#1387;&#1406;&#1398;&#1381;&#1408;&#1387; &#1377;&#1398;&#1391;&#1377;&#1389; &#1402;&#1377;&#1392;&#1377;&#1402;&#1377;&#1398;&#1400;&#1410;&#1396;"
             data-en="Segregated asset custody and safekeeping">Segregated asset custody and safekeeping</p>
        </div>

        <div class="gs-reveal-scale glass-card p-8 text-center">
          <div class="w-12 h-12 mx-auto mb-5 border border-gold-400/25 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971z" />
            </svg>
          </div>
          <h3 class="font-heading text-lg text-card-title font-semibold mb-2" data-i18n data-hy="&#1339;&#1408;&#1377;&#1406;&#1377;&#1391;&#1377;&#1398; &#1341;&#1400;&#1408;&#1392;&#1408;&#1380;&#1377;&#1407;&#1400;&#1410;" data-en="Legal Counsel">Legal Counsel</h3>
          <p class="text-gold-soft text-[14px] font-medium mb-2" data-i18n data-hy="&#1329;&#1404;&#1377;&#1403;&#1377;&#1407;&#1377;&#1408; &#1339;&#1408;&#1377;&#1406;&#1377;&#1378;&#1377;&#1398;&#1377;&#1391;&#1377;&#1398; &#1336;&#1398;&#1391;&#1381;&#1408;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;" data-en="Leading Armenian Law Firm">Leading Armenian Law Firm</p>
          <p class="text-card-body-muted text-[13px] font-light leading-relaxed" data-i18n
             data-hy="&#1339;&#1408;&#1377;&#1406;&#1377;&#1391;&#1377;&#1398; &#1392;&#1377;&#1396;&#1377;&#1402;&#1377;&#1407;&#1377;&#1405;&#1389;&#1377;&#1398;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398; &#1415; &#1391;&#1377;&#1404;&#1400;&#1410;&#1409;&#1406;&#1377;&#1390;&#1412;&#1377;&#1397;&#1387;&#1398; &#1377;&#1403;&#1377;&#1391;&#1409;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;"
             data-en="Regulatory compliance and fund structuring">Regulatory compliance and fund structuring</p>
        </div>

        <div class="gs-reveal-scale glass-card p-8 text-center">
          <div class="w-12 h-12 mx-auto mb-5 border border-gold-400/25 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
            </svg>
          </div>
          <h3 class="font-heading text-lg text-card-title font-semibold mb-2" data-i18n data-hy="&#1329;&#1380;&#1396;&#1387;&#1398;&#1387;&#1405;&#1407;&#1408;&#1377;&#1407;&#1400;&#1408;" data-en="Fund Administrator">Fund Administrator</h3>
          <p class="text-gold-soft text-[14px] font-medium mb-2" data-i18n data-hy="&#1329;&#1398;&#1391;&#1377;&#1389; &#1329;&#1380;&#1396;&#1387;&#1398;&#1387;&#1405;&#1407;&#1408;&#1377;&#1407;&#1400;&#1408;" data-en="Independent Administrator">Independent Administrator</p>
          <p class="text-card-body-muted text-[13px] font-light leading-relaxed" data-i18n
             data-hy="&#1366;&#1400;&#1398;&#1380;&#1387; &#1392;&#1377;&#1399;&#1406;&#1377;&#1402;&#1377;&#1392;&#1400;&#1410;&#1396; &#1415; NAV &#1392;&#1377;&#1399;&#1406;&#1377;&#1408;&#1391;&#1400;&#1410;&#1396;"
             data-en="Fund accounting and NAV calculation">Fund accounting and NAV calculation</p>
        </div>
      </div>
    </div>
  </section>

---
// Governance & Values section
import SectionHeader from '../SectionHeader.astro';
import GlassCard from '../GlassCard.astro';
---
<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
    <div class="absolute bottom-0 right-0 w-[500px] h-[500px] ambient-blob bg-gold-400"></div>

    <div class="section-inner max-w-[1200px] mx-auto px-6 lg:px-20 relative z-10">
      <div class="text-center mb-20">
        <SectionHeader label="Governance & Values" labelHy="&#1343;&#1377;&#1404;&#1377;&#1406;&#1377;&#1408;&#1400;&#1410;&#1396; &#1415; &#1329;&#1408;&#1386;&#1381;&#1412;&#1398;&#1381;&#1408;" centered>
          <h2 class="font-heading text-3xl sm:text-4xl lg:text-[3rem] text-text-primary font-semibold leading-[1.1]">
            <span data-i18n data-hy="&#1331;&#1381;&#1408;&#1377;&#1382;&#1377;&#1398;&#1409;&#1400;&#1410;&#1385;&#1397;&#1377;&#1398;, &#1385;&#1377;&#1411;&#1377;&#1398;&#1409;&#1387;&#1391;&#1400;&#1410;&#1385;&#1397;&#1377;&#1398; &#1415; <span class='text-gold-gradient'>&#1406;&#1405;&#1407;&#1377;&#1392;&#1381;&#1388;&#1387;&#1400;&#1410;&#1385;&#1397;&#1377;&#1398;</span> &#1406;&#1408;&#1377; &#1391;&#1377;&#1404;&#1400;&#1410;&#1409;&#1406;&#1377;&#1390;" data-en="Built on Excellence, Transparency &amp; <span class='text-gold-gradient'>Trust</span>">Built on Excellence, Transparency &amp; <span class="text-gold-gradient">Trust</span></span>
          </h2>
        </SectionHeader>
      </div>

      <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
        <GlassCard
          title="Regulatory Compliance"
          titleHy="&#1343;&#1377;&#1408;&#1379;&#1377;&#1406;&#1400;&#1408;&#1396;&#1377;&#1398; &#1344;&#1377;&#1396;&#1377;&#1402;&#1377;&#1407;&#1377;&#1405;&#1389;&#1377;&#1398;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;"
          iconPath="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z"
        >
          <p class="text-card-body font-light leading-[1.8] text-[15px]" data-i18n
             data-hy="&#1340;&#1387;&#1409;&#1381;&#1398;&#1382;&#1377;&#1406;&#1400;&#1408;&#1406;&#1377;&#1390; &#1344;&#1377;&#1397;&#1377;&#1405;&#1407;&#1377;&#1398;&#1387; &#1343;&#1381;&#1398;&#1407;&#1408;&#1400;&#1398;&#1377;&#1391;&#1377;&#1398; &#1330;&#1377;&#1398;&#1391;&#1387; &#1391;&#1400;&#1394;&#1396;&#1387;&#1409;&#1417; &#1348;&#1381;&#1398;&#1412; &#1379;&#1400;&#1408;&#1390;&#1400;&#1410;&#1396; &#1381;&#1398;&#1412; &#1377;&#1396;&#1381;&#1398;&#1377;&#1378;&#1377;&#1408;&#1393;&#1408; &#1391;&#1377;&#1408;&#1379;&#1377;&#1406;&#1400;&#1408;&#1396;&#1377;&#1398; &#1401;&#1377;&#1411;&#1377;&#1398;&#1387;&#1399;&#1398;&#1381;&#1408;&#1400;&#1406;&#1417;"
             data-en="As one of only five licensed fund managers in Armenia, we adhere to strict CBA regulations covering capital adequacy, risk management, reporting, and investor protection. Our operations are subject to regular audits and regulatory review.">
            As one of only five licensed fund managers in Armenia, we adhere to strict CBA regulations covering capital adequacy, risk management, reporting, and investor protection. Our operations are subject to regular audits and regulatory review.
          </p>
        </GlassCard>

        <GlassCard
          title="Transparency"
          titleHy="&#1337;&#1377;&#1411;&#1377;&#1398;&#1409;&#1387;&#1391;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;"
          iconPath="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"
          iconPath2="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
        >
          <p class="text-card-body font-light leading-[1.8] text-[15px]" data-i18n
             data-hy="&#1348;&#1381;&#1408; &#1398;&#1381;&#1408;&#1380;&#1408;&#1400;&#1394;&#1398;&#1381;&#1408;&#1384; &#1405;&#1407;&#1377;&#1398;&#1400;&#1410;&#1396; &#1381;&#1398; &#1396;&#1377;&#1398;&#1408;&#1377;&#1396;&#1377;&#1405;&#1398; &#1392;&#1377;&#1399;&#1406;&#1381;&#1407;&#1406;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;&#1398;&#1381;&#1408;&#1417;"
             data-en="Every investor receives comprehensive quarterly reports, annual audited financials, and timely disclosure of material events. We believe informed investors make better decisions &mdash; and better decisions lead to better outcomes for everyone.">
            Every investor receives comprehensive quarterly reports, annual audited financials, and timely disclosure of material events. We believe informed investors make better decisions &mdash; and better decisions lead to better outcomes for everyone.
          </p>
        </GlassCard>

        <GlassCard
          title="Fiduciary Duty"
          titleHy="&#1358;&#1405;&#1407;&#1377;&#1392;&#1381;&#1388;&#1387; &#1354;&#1377;&#1408;&#1407;&#1377;&#1391;&#1377;&#1398;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;"
          iconPath="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
        >
          <p class="text-card-body font-light leading-[1.8] text-[15px]" data-i18n
             data-hy="&#1350;&#1381;&#1408;&#1380;&#1408;&#1400;&#1394;&#1398;&#1381;&#1408;&#1387; &#1399;&#1377;&#1392;&#1381;&#1408;&#1384; &#1396;&#1381;&#1408; &#1377;&#1404;&#1377;&#1403;&#1398;&#1377;&#1392;&#1381;&#1408;&#1385;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;&#1398; &#1381;&#1398;&#1417;"
             data-en="Our investors' interests come first &mdash; always. Every decision we make is guided by a strict fiduciary standard. We align our incentives with our investors through co-investment and performance-based fee structures.">
            Our investors' interests come first &mdash; always. Every decision we make is guided by a strict fiduciary standard. We align our incentives with our investors through co-investment and performance-based fee structures.
          </p>
        </GlassCard>
      </div>
    </div>
  </section>

---
// Corporate Governance Structure / Framework
import SectionHeader from '../SectionHeader.astro';
---
<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
    <div class="absolute top-1/4 right-0 w-[400px] h-[400px] ambient-blob bg-gold-400"></div>

    <div class="section-inner max-w-[1200px] mx-auto px-6 lg:px-20 relative z-10">
      <div class="text-center mb-16">
        <SectionHeader label="Corporate Structure" labelHy="&#1343;&#1400;&#1408;&#1402;&#1400;&#1408;&#1377;&#1407;&#1387;&#1406; &#1343;&#1377;&#1404;&#1400;&#1410;&#1409;&#1406;&#1377;&#1390;&#1412;" centered>
          <h2 class="font-heading text-3xl sm:text-4xl lg:text-[3rem] text-text-primary font-semibold leading-[1.1]">
            <span data-i18n data-hy="&#1343;&#1377;&#1404;&#1377;&#1406;&#1377;&#1408;&#1396;&#1377;&#1398; <span class='text-gold-gradient'>&#1343;&#1377;&#1404;&#1400;&#1410;&#1409;&#1406;&#1377;&#1390;&#1412;</span>" data-en="Governance <span class='text-gold-gradient'>Framework</span>">Governance <span class="text-gold-gradient">Framework</span></span>
          </h2>
        </SectionHeader>
      </div>

      <!-- Governance Flow -->
      <div class="gs-reveal max-w-[900px] mx-auto">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="glass-card p-8 text-center">
            <div class="w-12 h-12 mx-auto mb-4 border border-gold-400/30 rounded-full flex items-center justify-center">
              <span class="text-gold-gradient font-heading text-lg font-semibold" data-i18n data-hy="&#1329;" data-en="B">B</span>
            </div>
            <h3 class="font-heading text-lg text-card-title font-semibold mb-2" data-i18n data-hy="&#1341;&#1400;&#1408;&#1392;&#1408;&#1380;&#1377;&#1407;&#1406;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;" data-en="Board of Directors">Board of Directors</h3>
            <p class="text-card-body-muted text-[13px] font-light leading-relaxed" data-i18n
               data-hy="&#1356;&#1377;&#1382;&#1396;&#1377;&#1406;&#1377;&#1408;&#1377;&#1391;&#1377;&#1398; &#1406;&#1381;&#1408;&#1377;&#1392;&#1405;&#1391;&#1400;&#1394;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398; &#1415; &#1413;&#1408;&#1381;&#1398;&#1405;&#1380;&#1408;&#1377;&#1391;&#1377;&#1398; &#1392;&#1377;&#1396;&#1377;&#1402;&#1377;&#1407;&#1377;&#1405;&#1389;&#1377;&#1398;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;"
               data-en="Strategic oversight and regulatory compliance governance">Strategic oversight and regulatory compliance governance</p>
          </div>
          <div class="glass-card p-8 text-center">
            <div class="w-12 h-12 mx-auto mb-4 border border-gold-400/30 rounded-full flex items-center justify-center">
              <span class="text-gold-gradient font-heading text-lg font-semibold" data-i18n data-hy="&#1350;" data-en="IC">IC</span>
            </div>
            <h3 class="font-heading text-lg text-card-title font-semibold mb-2" data-i18n data-hy="&#1350;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;&#1377;&#1397;&#1387;&#1398; &#1343;&#1400;&#1396;&#1387;&#1407;&#1381;" data-en="Investment Committee">Investment Committee</h3>
            <p class="text-card-body-muted text-[13px] font-light leading-relaxed" data-i18n
               data-hy="&#1350;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;&#1377;&#1397;&#1387;&#1398; &#1400;&#1408;&#1400;&#1399;&#1400;&#1410;&#1396;&#1398;&#1381;&#1408;&#1387; &#1396;&#1387;&#1377;&#1393;&#1377;&#1397;&#1398; &#1392;&#1377;&#1405;&#1407;&#1377;&#1407;&#1400;&#1410;&#1396;"
               data-en="Unanimous approval required for all investment decisions">Unanimous approval required for all investment decisions</p>
          </div>
          <div class="glass-card p-8 text-center">
            <div class="w-12 h-12 mx-auto mb-4 border border-gold-400/30 rounded-full flex items-center justify-center">
              <span class="text-gold-gradient font-heading text-lg font-semibold" data-i18n data-hy="&#1356;" data-en="RC">RC</span>
            </div>
            <h3 class="font-heading text-lg text-card-title font-semibold mb-2" data-i18n data-hy="&#1356;&#1387;&#1405;&#1391;&#1381;&#1408;&#1387; &#1343;&#1400;&#1396;&#1387;&#1407;&#1381;" data-en="Risk Committee">Risk Committee</h3>
            <p class="text-card-body-muted text-[13px] font-light leading-relaxed" data-i18n
               data-hy="&#1356;&#1387;&#1405;&#1391;&#1381;&#1408;&#1387; &#1396;&#1400;&#1398;&#1387;&#1407;&#1400;&#1408;&#1387;&#1398;&#1379; &#1415; &#1402;&#1400;&#1408;&#1407;&#1414;&#1381;&#1388;&#1387; &#1391;&#1377;&#1404;&#1377;&#1406;&#1377;&#1408;&#1400;&#1410;&#1396;"
               data-en="Ongoing risk monitoring and portfolio limits management">Ongoing risk monitoring and portfolio limits management</p>
          </div>
        </div>
      </div>
    </div>
  </section>

---
// Team / Leadership placeholder section
import SectionHeader from '../SectionHeader.astro';
---
<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
    <div class="absolute top-1/4 left-0 w-[400px] h-[400px] ambient-blob bg-gold-400"></div>

    <div class="section-inner max-w-[1200px] mx-auto px-6 lg:px-20 relative z-10">
      <SectionHeader label="Leadership" labelHy="&#1346;&#1381;&#1391;&#1377;&#1406;&#1377;&#1408;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;" />

      <h2 class="gs-reveal font-heading text-2xl sm:text-3xl lg:text-4xl text-text-primary font-semibold mb-12 leading-[1.15] mt-6">
        <span data-i18n data-hy="&#1348;&#1381;&#1408; <span class='text-gold-gradient'>&#1337;&#1387;&#1396;&#1384;</span>" data-en="Our <span class='text-gold-gradient'>Team</span>">Our <span class="text-gold-gradient">Team</span></span>
      </h2>

      <div class="gs-reveal glass-card p-10 lg:p-14 max-w-[720px]">
        <p class="text-card-body text-[16px] font-light leading-[1.8] mb-8" data-i18n
           data-hy="&#1348;&#1381;&#1408; &#1385;&#1387;&#1396;&#1384; &#1396;&#1387;&#1377;&#1406;&#1400;&#1408;&#1400;&#1410;&#1396; &#1383; &#1396;&#1387;&#1403;&#1377;&#1382;&#1379;&#1377;&#1397;&#1387;&#1398; &#1411;&#1400;&#1408;&#1393;&#1377;&#1404;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398; &#1415; &#1407;&#1381;&#1394;&#1377;&#1391;&#1377;&#1398; &#1379;&#1387;&#1407;&#1381;&#1388;&#1387;&#1412;&#1398;&#1381;&#1408;&#1417;"
           data-en="Our leadership team combines international experience across investment banking, asset management, and financial technology with deep knowledge of the Armenian market. Profiles of our team members and advisory board will be available soon.">
          Our leadership team combines international experience across investment banking, asset management, and financial technology with deep knowledge of the Armenian market. Profiles of our team members and advisory board will be available soon.
        </p>
        <div class="flex items-center gap-4">
          <div class="h-px w-10 bg-gradient-to-r from-gold-400/20 to-transparent"></div>
          <p class="text-est-text text-[0.65rem] tracking-[0.2em] uppercase font-light" data-i18n data-hy="&#1337;&#1387;&#1396;&#1387; &#1383;&#1403;&#1384; &#1399;&#1400;&#1410;&#1407;&#1400;&#1406;" data-en="Team profiles coming soon">Team profiles coming soon</p>
        </div>
      </div>
    </div>
  </section>

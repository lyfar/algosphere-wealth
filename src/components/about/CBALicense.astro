---
// CBA License & Regulatory section
import SectionHeader from '../SectionHeader.astro';
---
<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
  <div class="absolute bottom-0 right-0 w-[500px] h-[500px] ambient-blob bg-gold-400"></div>

  <div class="section-inner max-w-[1200px] mx-auto px-6 lg:px-20 relative z-10">
    <div class="text-center mb-16">
      <SectionHeader label="Regulatory Status" labelHy="&#1343;&#1377;&#1408;&#1379;&#1377;&#1406;&#1400;&#1408;&#1396;&#1377;&#1398; &#1343;&#1377;&#1408;&#1379;&#1377;&#1406;&#1387;&#1395;&#1377;&#1391;" centered>
        <h2 class="font-heading text-3xl sm:text-4xl lg:text-[3rem] text-text-primary font-semibold leading-[1.1]">
          <span data-i18n data-hy="&#1340;&#1387;&#1409;&#1381;&#1398;&#1382;&#1377;&#1406;&#1400;&#1408;&#1406;&#1377;&#1390; <span class='text-gold-gradient'>&#1344;&#1377;&#1397;&#1377;&#1405;&#1407;&#1377;&#1398;&#1387; &#1343;&#1381;&#1398;&#1407;&#1408;&#1400;&#1398;&#1377;&#1391;&#1377;&#1398; &#1330;&#1377;&#1398;&#1391;&#1387;</span> &#1391;&#1400;&#1394;&#1396;&#1387;&#1409;" data-en="Licensed by the <span class='text-gold-gradient'>Central Bank of Armenia</span>">Licensed by the <span class="text-gold-gradient">Central Bank of Armenia</span></span>
        </h2>
      </SectionHeader>
    </div>

    <div class="gs-reveal glass-card p-10 lg:p-14 max-w-[900px] mx-auto">
      <div class="flex items-center gap-4 mb-8">
        <div class="w-12 h-12 border border-gold-400/30 rounded-full flex items-center justify-center">
          <svg class="w-6 h-6 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
        </div>
        <div>
          <p class="text-text-primary text-[17px] font-medium" data-i18n
             data-hy="&#1350;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;&#1377;&#1397;&#1387;&#1398; &#1366;&#1400;&#1398;&#1380;&#1381;&#1408;&#1387; &#1343;&#1377;&#1404;&#1377;&#1406;&#1377;&#1408;&#1387;&#1401;"
             data-en="Investment Fund Manager">Investment Fund Manager</p>
          <p class="text-card-body-muted text-[14px] font-light" data-i18n
             data-hy="&#1344;&#1344; &#1343;&#1381;&#1398;&#1407;&#1408;&#1400;&#1398;&#1377;&#1391;&#1377;&#1398; &#1330;&#1377;&#1398;&#1391;&#1387; &#1388;&#1387;&#1409;&#1381;&#1398;&#1382;&#1387;&#1377;"
             data-en="Central Bank of Armenia License">Central Bank of Armenia License</p>
        </div>
      </div>
      <div class="space-y-4 text-[15px] text-card-body font-light leading-[1.8]">
        <p data-i18n
           data-hy="Algosphere Asset Management &#1357;&#1354;&#1336;-&#1398; &#1388;&#1387;&#1409;&#1381;&#1398;&#1382;&#1377;&#1406;&#1400;&#1408;&#1406;&#1377;&#1390; &#1383; &#1344;&#1377;&#1397;&#1377;&#1405;&#1407;&#1377;&#1398;&#1387; &#1344;&#1377;&#1398;&#1408;&#1377;&#1402;&#1381;&#1407;&#1400;&#1410;&#1385;&#1397;&#1377;&#1398; &#1343;&#1381;&#1398;&#1407;&#1408;&#1400;&#1398;&#1377;&#1391;&#1377;&#1398; &#1330;&#1377;&#1398;&#1391;&#1387; &#1391;&#1400;&#1394;&#1396;&#1387;&#1409;&#1373; &#1400;&#1408;&#1402;&#1381;&#1405; &#1398;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;&#1377;&#1397;&#1387;&#1398; &#1411;&#1400;&#1398;&#1380;&#1381;&#1408;&#1387; &#1391;&#1377;&#1404;&#1377;&#1406;&#1377;&#1408;&#1387;&#1401;&#1417; &#1348;&#1381;&#1398;&#1412; &#1379;&#1400;&#1408;&#1390;&#1400;&#1410;&#1396; &#1381;&#1398;&#1412; &#1344;&#1344; &laquo;&#1350;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;&#1377;&#1397;&#1387;&#1398; &#1411;&#1000;&#1398;&#1380;&#1381;&#1408;&#1387; &#1396;&#1377;&#1405;&#1387;&#1398;&raquo; &#1415; &laquo;&#1329;&#1408;&#1386;&#1381;&#1385;&#1394;&#1385;&#1381;&#1408;&#1387; &#1399;&#1000;&#1410;&#1391;&#1377;&#1397;&#1387; &#1396;&#1377;&#1405;&#1387;&#1398;&raquo; &#1413;&#1408;&#1381;&#1398;&#1412;&#1398;&#1381;&#1408;&#1387; &#1392;&#1377;&#1396;&#1377;&#1393;&#1377;&#1397;&#1398;&#1417;"
           data-en="Algosphere Asset Management LLC is licensed by the Central Bank of Armenia as an investment fund manager. We operate in full compliance with the Republic of Armenia Law on Investment Funds, the Law on Securities Market, and all applicable CBA regulations governing capital adequacy, risk management, reporting, and investor protection.">
          Algosphere Asset Management LLC is licensed by the Central Bank of Armenia as an investment fund manager. We operate in full compliance with the Republic of Armenia Law on Investment Funds, the Law on Securities Market, and all applicable CBA regulations governing capital adequacy, risk management, reporting, and investor protection.
        </p>
      </div>
      <div class="grid sm:grid-cols-3 gap-6 mt-10 pt-8 border-t border-white/[0.06]">
        <div class="text-center">
          <p class="text-gold-gradient font-heading text-2xl font-semibold" data-i18n data-hy="&#1343;&#1330;" data-en="CBA">CBA</p>
          <p class="text-card-body-muted text-[12px] font-light mt-1" data-i18n data-hy="&#1343;&#1377;&#1408;&#1379;&#1377;&#1406;&#1400;&#1408;&#1387;&#1401;" data-en="Regulator">Regulator</p>
        </div>
        <div class="text-center">
          <p class="text-gold-gradient font-heading text-2xl font-semibold" data-i18n data-hy="5-&#1387;&#1409; 1" data-en="1 of 5">1 of 5</p>
          <p class="text-card-body-muted text-[12px] font-light mt-1" data-i18n data-hy="&#1340;&#1387;&#1409;&#1381;&#1398;&#1382;&#1377;&#1406;&#1400;&#1408;&#1406;&#1377;&#1390; &#1391;&#1377;&#1404;&#1377;&#1406;&#1377;&#1408;&#1387;&#1401;&#1398;&#1381;&#1408;" data-en="Licensed Fund Managers in Armenia">Licensed Fund Managers in Armenia</p>
        </div>
        <div class="text-center">
          <p class="text-gold-gradient font-heading text-2xl font-semibold" data-i18n data-hy="&#1340;&#1387;&#1377;&#1408;&#1386;&#1381;&#1412;" data-en="Full">Full</p>
          <p class="text-card-body-muted text-[12px] font-light mt-1" data-i18n data-hy="&#1344;&#1377;&#1396;&#1377;&#1402;&#1377;&#1407;&#1377;&#1405;&#1389;&#1377;&#1398;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;" data-en="Regulatory Compliance">Regulatory Compliance</p>
        </div>
      </div>
    </div>
  </div>
</section>

---
// Embedded Google Map section
---
<section class="relative py-16 sm:py-24 overflow-hidden section-navy">
    <div class="section-inner max-w-[1200px] mx-auto px-6 lg:px-20 relative z-10">
      <div class="gs-reveal">
        <div class="glass-card overflow-hidden rounded-2xl">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3048.2!2d44.5053!3d40.1792!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x406aa2dab8fc8b5b%3A0x3d1479ae87da526a!2sArgishtii%20St%2C%20Yerevan%2C%20Armenia!5e0!3m2!1sen!2s!4v1706000000000!5m2!1sen!2s"
            width="100%"
            height="400"
            style="border:0; filter: grayscale(0.8) contrast(1.1) brightness(0.6); opacity: 0.9;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Algosphere Office - Yerevan, Armenia"
          ></iframe>
        </div>
        <div class="text-center mt-6">
          <a href="https://maps.google.com/?q=Argishtii+7/6+Yerevan+Armenia" target="_blank" rel="noopener"
             class="inline-flex items-center gap-2 text-[0.7rem] tracking-[0.15em] uppercase text-gold-soft hover:text-gold-400 transition-colors duration-400 font-normal">
            <span data-i18n data-hy="&#1330;&#1377;&#1409;&#1381;&#1388; Google Maps-&#1400;&#1410;&#1396;" data-en="Open in Google Maps">Open in Google Maps</span>
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

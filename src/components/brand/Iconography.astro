---
/**
 * Iconography — 12-icon grid with labels + usage rules card.
 * All Heroicons outline, 24×24, 1.5px stroke.
 */
---

<section class="relative py-24 sm:py-32 overflow-hidden">
  <div class="section-inner max-w-[1200px] mx-auto px-6 lg:px-20 relative z-10">

    <div class="gs-reveal mb-6">
      <div class="section-accent" id="accent-line-5"></div>
      <p class="section-label">Iconography</p>
    </div>

    <div class="gs-reveal mt-8 mb-16">
      <p class="text-[17px] text-card-body font-light leading-[1.75] max-w-[720px]">
        All icons use the Heroicons outline set (24×24, 1.5px stroke). Consistent weight, minimal detail, always in the accent color at reduced opacity.
      </p>
    </div>

    <!-- Icon grid -->
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-4">

      <!-- Shield Check — Trust/Security -->
      <div class="gs-reveal-scale glass-card p-6 flex flex-col items-center gap-3 text-center">
        <svg class="w-7 h-7 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
        </svg>
        <span class="text-[0.6rem] tracking-[0.1em] uppercase text-card-body-muted font-medium">Trust</span>
      </div>

      <!-- Chart Bar — Performance -->
      <div class="gs-reveal-scale glass-card p-6 flex flex-col items-center gap-3 text-center">
        <svg class="w-7 h-7 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
        </svg>
        <span class="text-[0.6rem] tracking-[0.1em] uppercase text-card-body-muted font-medium">Performance</span>
      </div>

      <!-- Globe — Global Reach -->
      <div class="gs-reveal-scale glass-card p-6 flex flex-col items-center gap-3 text-center">
        <svg class="w-7 h-7 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
        </svg>
        <span class="text-[0.6rem] tracking-[0.1em] uppercase text-card-body-muted font-medium">Global</span>
      </div>

      <!-- Scale — Balance/Compliance -->
      <div class="gs-reveal-scale glass-card p-6 flex flex-col items-center gap-3 text-center">
        <svg class="w-7 h-7 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971z" />
        </svg>
        <span class="text-[0.6rem] tracking-[0.1em] uppercase text-card-body-muted font-medium">Compliance</span>
      </div>

      <!-- Lock Closed — Security -->
      <div class="gs-reveal-scale glass-card p-6 flex flex-col items-center gap-3 text-center">
        <svg class="w-7 h-7 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
        </svg>
        <span class="text-[0.6rem] tracking-[0.1em] uppercase text-card-body-muted font-medium">Security</span>
      </div>

      <!-- Building Office — Institution -->
      <div class="gs-reveal-scale glass-card p-6 flex flex-col items-center gap-3 text-center">
        <svg class="w-7 h-7 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
        </svg>
        <span class="text-[0.6rem] tracking-[0.1em] uppercase text-card-body-muted font-medium">Institution</span>
      </div>

      <!-- Arrow Trending Up — Growth -->
      <div class="gs-reveal-scale glass-card p-6 flex flex-col items-center gap-3 text-center">
        <svg class="w-7 h-7 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
        </svg>
        <span class="text-[0.6rem] tracking-[0.1em] uppercase text-card-body-muted font-medium">Growth</span>
      </div>

      <!-- Users — Team/Clients -->
      <div class="gs-reveal-scale glass-card p-6 flex flex-col items-center gap-3 text-center">
        <svg class="w-7 h-7 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
        </svg>
        <span class="text-[0.6rem] tracking-[0.1em] uppercase text-card-body-muted font-medium">Clients</span>
      </div>

      <!-- Document Text — Reports -->
      <div class="gs-reveal-scale glass-card p-6 flex flex-col items-center gap-3 text-center">
        <svg class="w-7 h-7 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
        </svg>
        <span class="text-[0.6rem] tracking-[0.1em] uppercase text-card-body-muted font-medium">Reports</span>
      </div>

      <!-- Phone — Contact -->
      <div class="gs-reveal-scale glass-card p-6 flex flex-col items-center gap-3 text-center">
        <svg class="w-7 h-7 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        <span class="text-[0.6rem] tracking-[0.1em] uppercase text-card-body-muted font-medium">Contact</span>
      </div>

      <!-- Envelope — Email -->
      <div class="gs-reveal-scale glass-card p-6 flex flex-col items-center gap-3 text-center">
        <svg class="w-7 h-7 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
        <span class="text-[0.6rem] tracking-[0.1em] uppercase text-card-body-muted font-medium">Email</span>
      </div>

      <!-- Map Pin — Location -->
      <div class="gs-reveal-scale glass-card p-6 flex flex-col items-center gap-3 text-center">
        <svg class="w-7 h-7 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
        </svg>
        <span class="text-[0.6rem] tracking-[0.1em] uppercase text-card-body-muted font-medium">Location</span>
      </div>

    </div>

    <!-- Icon usage note -->
    <div class="gs-reveal mt-10">
      <div class="glass-card p-8">
        <p class="text-[0.68rem] tracking-[0.14em] uppercase font-medium text-gold-accent mb-3">Usage Rules</p>
        <ul class="space-y-2 text-[15px] text-card-body font-light leading-[1.7]">
          <li><strong class="text-text-primary">Set:</strong> Heroicons Outline v2 (24×24 viewport, 1.5px stroke)</li>
          <li><strong class="text-text-primary">Color:</strong> Always use the accent token (<code class="text-[0.8rem] font-mono text-gold-accent">text-gold-accent</code>). Never fill, only stroke.</li>
          <li><strong class="text-text-primary">Size:</strong> 18–28px depending on context. Cards use 20px, features use 24px, hero icons 28px.</li>
          <li><strong class="text-text-primary">Containers:</strong> Rounded square (<code class="text-[0.8rem] font-mono text-gold-accent">rounded-xl</code>) with glass border and 3% accent background.</li>
          <li><strong class="text-text-primary">Consistency:</strong> Do not mix icon sets. No solid/filled variants, no custom SVGs outside this set.</li>
        </ul>
      </div>
    </div>

  </div>
</section>

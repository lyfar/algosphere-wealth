---
// Privacy Policy section
import SectionHeader from '../SectionHeader.astro';
---
<section class="relative py-24 sm:py-32 overflow-hidden">
    <div class="absolute top-1/4 right-1/4 w-[400px] h-[400px] ambient-blob bg-gold-400"></div>

    <div class="section-inner max-w-[900px] mx-auto px-6 lg:px-20 relative z-10">
      <SectionHeader label="Privacy Policy" labelHy="&#1331;&#1377;&#1394;&#1407;&#1398;&#1387;&#1400;&#1410;&#1385;&#1397;&#1377;&#1398; &#1364;&#1377;&#1394;&#1377;&#1412;&#1377;&#1391;&#1377;&#1398;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;" />

      <div class="gs-reveal mt-8 space-y-8">
        <div>
          <h3 class="font-heading text-xl text-text-primary font-semibold mb-4" data-i18n data-hy="&#1359;&#1406;&#1397;&#1377;&#1388;&#1398;&#1381;&#1408;&#1387; &#1344;&#1377;&#1406;&#1377;&#1412;&#1377;&#1379;&#1408;&#1400;&#1410;&#1396;" data-en="Data Collection">Data Collection</h3>
          <p class="text-[15px] text-card-body font-light leading-[1.8]" data-i18n
             data-hy="&#1348;&#1381;&#1398;&#1412; &#1392;&#1377;&#1406;&#1377;&#1412;&#1377;&#1379;&#1408;&#1400;&#1410;&#1396; &#1381;&#1398;&#1412; &#1396;&#1387;&#1377;&#1397;&#1398; &#1377;&#1397;&#1398; &#1377;&#1398;&#1393;&#1398;&#1377;&#1391;&#1377;&#1398; &#1407;&#1406;&#1397;&#1377;&#1388;&#1398;&#1381;&#1408;&#1384;, &#1400;&#1408;&#1400;&#1398;&#1412; &#1380;&#1400;&#1410;&#1412; &#1391;&#1377;&#1396;&#1377;&#1406;&#1400;&#1408; &#1407;&#1408;&#1377;&#1396;&#1377;&#1380;&#1408;&#1400;&#1410;&#1396; &#1381;&#1412; &#1396;&#1381;&#1382;&#1417;"
             data-en="We collect only the personal information you voluntarily provide through our contact form, including your name, email address, and the content of your message. We do not use tracking cookies or third-party analytics tools that collect personal data. Your information is used solely to respond to your inquiry.">
            We collect only the personal information you voluntarily provide through our contact form, including your name, email address, and the content of your message. We do not use tracking cookies or third-party analytics tools that collect personal data. Your information is used solely to respond to your inquiry.
          </p>
        </div>

        <div>
          <h3 class="font-heading text-xl text-text-primary font-semibold mb-4" data-i18n data-hy="&#1359;&#1406;&#1397;&#1377;&#1388;&#1398;&#1381;&#1408;&#1387; &#1354;&#1377;&#1399;&#1407;&#1402;&#1377;&#1398;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;" data-en="Data Protection">Data Protection</h3>
          <p class="text-[15px] text-card-body font-light leading-[1.8]" data-i18n
             data-hy="&#1348;&#1381;&#1398;&#1412; &#1393;&#1379;&#1407;&#1400;&#1410;&#1396; &#1381;&#1398;&#1412; &#1392;&#1377;&#1396;&#1377;&#1402;&#1377;&#1407;&#1377;&#1405;&#1389;&#1377;&#1398; &#1396;&#1387;&#1403;&#1400;&#1409;&#1398;&#1381;&#1408; &#1393;&#1381;&#1408; &#1407;&#1406;&#1397;&#1377;&#1388;&#1398;&#1381;&#1408;&#1387; &#1402;&#1377;&#1399;&#1407;&#1402;&#1377;&#1398;&#1400;&#1410;&#1385;&#1397;&#1377;&#1398; &#1392;&#1377;&#1396;&#1377;&#1408;&#1417;"
             data-en="We implement appropriate technical and organizational measures to protect your personal data against unauthorized access, alteration, disclosure, or destruction. For investors within the European Union, we comply with the General Data Protection Regulation (GDPR) requirements regarding the processing of personal data.">
            We implement appropriate technical and organizational measures to protect your personal data against unauthorized access, alteration, disclosure, or destruction. For investors within the European Union, we comply with the General Data Protection Regulation (GDPR) requirements regarding the processing of personal data.
          </p>
        </div>

        <div>
          <h3 class="font-heading text-xl text-text-primary font-semibold mb-4" data-i18n data-hy="&#1345;&#1381;&#1408; &#1339;&#1408;&#1377;&#1406;&#1400;&#1410;&#1398;&#1412;&#1398;&#1381;&#1408;&#1384;" data-en="Your Rights">Your Rights</h3>
          <p class="text-[15px] text-card-body font-light leading-[1.8]" data-i18n
             data-hy="&#1332;&#1400;&#1410;&#1412; &#1387;&#1408;&#1377;&#1406;&#1400;&#1410;&#1398;&#1412; &#1400;&#1410;&#1398;&#1381;&#1412; &#1393;&#1381;&#1408; &#1377;&#1398;&#1393;&#1398;&#1377;&#1391;&#1377;&#1398; &#1407;&#1406;&#1397;&#1377;&#1388;&#1398;&#1381;&#1408;&#1387; &#1392;&#1377;&#1405;&#1377;&#1398;&#1381;&#1388;&#1387;&#1400;&#1410;&#1385;&#1397;&#1377;&#1398;, &#1400;&#1410;&#1394;&#1394;&#1396;&#1377;&#1398; &#1391;&#1377;&#1396; &#1403;&#1398;&#1403;&#1396;&#1377;&#1398; &#1392;&#1377;&#1396;&#1377;&#1408;&#1417;"
             data-en="You have the right to access, correct, or delete your personal data at any time. You may also request information about how your data is being processed. To exercise these rights, please contact us at info@algosphere.am.">
            You have the right to access, correct, or delete your personal data at any time. You may also request information about how your data is being processed. To exercise these rights, please contact us at <a href="mailto:info@algosphere.am" class="text-gold-accent hover:text-gold-400 transition-colors">info@algosphere.am</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

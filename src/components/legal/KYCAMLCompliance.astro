import SectionHeader from '../SectionHeader.astro';
---
<section class="relative py-24 sm:py-32 overflow-hidden section-navy">
    <div class="absolute bottom-0 left-1/3 w-[400px] h-[400px] ambient-blob bg-gold-400"></div>

    <div class="section-inner max-w-[900px] mx-auto px-6 lg:px-20 relative z-10">
      <SectionHeader label="KYC / AML Compliance" labelHy="KYC / AML &#1344;&#1377;&#1396;&#1377;&#1402;&#1377;&#1407;&#1377;&#1405;&#1389;&#1377;&#1398;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;" />

      <div class="gs-reveal mt-8 space-y-6 text-[15px] text-card-body font-light leading-[1.8]">
        <p data-i18n
           data-hy="&#1336;&#1398;&#1391;&#1381;&#1408;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;&#1384; &#1392;&#1377;&#1396;&#1377;&#1402;&#1377;&#1407;&#1377;&#1405;&#1389;&#1377;&#1398;&#1400;&#1410;&#1396; &#1383; &#1344;&#1377;&#1397;&#1377;&#1405;&#1407;&#1377;&#1398;&#1387; &#1344;&#1377;&#1398;&#1408;&#1377;&#1402;&#1381;&#1407;&#1400;&#1410;&#1385;&#1397;&#1377;&#1398; &#1411;&#1400;&#1394;&#1388;&#1406;&#1377;&#1390;&#1396;&#1377;&#1398; &#1380;&#1381;&#1396; &#1411;&#1400;&#1394;&#1388;&#1406;&#1377;&#1390;&#1396;&#1377;&#1398; &#1391;&#1377;&#1398;&#1389;&#1377;&#1408;&#1379;&#1381;&#1388;&#1396;&#1377;&#1398; &#1392;&#1377;&#1391;&#1377;&#1413;&#1408;&#1381;&#1398;&#1405;&#1380;&#1408;&#1400;&#1410;&#1385;&#1397;&#1377;&#1398;&#1384;&#1417;"
           data-en="The Company maintains comprehensive Know Your Customer (KYC) and Anti-Money Laundering (AML) procedures in accordance with the Republic of Armenia Law on Combating Money Laundering and Terrorism Financing and all applicable CBA directives.">
          The Company maintains comprehensive Know Your Customer (KYC) and Anti-Money Laundering (AML) procedures in accordance with the Republic of Armenia Law on Combating Money Laundering and Terrorism Financing and all applicable CBA directives.
        </p>
        <p data-i18n
           data-hy="&#1330;&#1400;&#1388;&#1400;&#1408; &#1402;&#1400;&#1407;&#1381;&#1398;&#1409;&#1387;&#1377;&#1388; &#1398;&#1381;&#1408;&#1380;&#1408;&#1400;&#1394;&#1398;&#1381;&#1408;&#1384; &#1402;&#1377;&#1408;&#1407;&#1377;&#1406;&#1400;&#1408; &#1381;&#1398; &#1377;&#1398;&#1409;&#1398;&#1381;&#1388; &#1387;&#1398;&#1412;&#1398;&#1400;&#1410;&#1385;&#1397;&#1377;&#1398; &#1405;&#1407;&#1400;&#1410;&#1379;&#1400;&#1410;&#1396; &#1415; &#1392;&#1377;&#1396;&#1377;&#1402;&#1377;&#1407;&#1377;&#1405;&#1389;&#1377;&#1398; &#1411;&#1377;&#1405;&#1407;&#1377;&#1385;&#1394;&#1385;&#1381;&#1408; &#1398;&#1381;&#1408;&#1391;&#1377;&#1397;&#1377;&#1409;&#1398;&#1381;&#1388;&#1417;"
           data-en="All prospective investors are required to complete identity verification and provide appropriate documentation before any subscription to fund units is accepted. This process ensures the integrity of our funds and protects the interests of all participants.">
          All prospective investors are required to complete identity verification and provide appropriate documentation before any subscription to fund units is accepted. This process ensures the integrity of our funds and protects the interests of all participants.
        </p>

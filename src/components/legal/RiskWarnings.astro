---
// Risk Warnings section (navy bg)
import SectionHeader from '../SectionHeader.astro';
---
<section class="relative py-24 sm:py-32 overflow-hidden section-navy">
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] ambient-blob bg-gold-400"></div>

    <div class="section-inner max-w-[900px] mx-auto px-6 lg:px-20 relative z-10">
      <SectionHeader label="Risk Warnings" labelHy="&#1356;&#1387;&#1405;&#1391;&#1381;&#1408;&#1387; &#1334;&#1379;&#1400;&#1410;&#1399;&#1377;&#1409;&#1400;&#1410;&#1396;&#1398;&#1381;&#1408;" />

      <div class="gs-reveal mt-8 glass-card p-8 lg:p-10">
        <div class="space-y-6 text-[15px] text-card-body font-light leading-[1.8]">
          <div class="flex items-start gap-4">
            <svg class="w-5 h-5 text-gold-accent shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <p data-i18n
               data-hy="&#1350;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;&#1398;&#1381;&#1408;&#1398; &#1384;&#1398;&#1380;&#1379;&#1408;&#1391;&#1400;&#1410;&#1396; &#1381;&#1398; &#1404;&#1387;&#1405;&#1391;&#1381;&#1408;&#1417; &#1350;&#1381;&#1408;&#1380;&#1408;&#1406;&#1377;&#1390; &#1379;&#1400;&#1410;&#1396;&#1377;&#1408;&#1398;&#1381;&#1408;&#1387; &#1377;&#1408;&#1386;&#1381;&#1412;&#1384; &#1391;&#1377;&#1408;&#1400;&#1394; &#1383; &#1387;&#1398;&#1401;&#1402;&#1381;&#1405; &#1377;&#1395;&#1381;&#1388;, &#1377;&#1397;&#1398;&#1402;&#1381;&#1405; &#1383;&#1388; &#1398;&#1406;&#1377;&#1382;&#1381;&#1388;&#1417;"
               data-en="All investments carry risk. The value of investments and the income derived from them may go down as well as up. Past performance is not a reliable indicator of future results. Investors may not recover the full amount of their original investment.">
              All investments carry risk. The value of investments and the income derived from them may go down as well as up. Past performance is not a reliable indicator of future results. Investors may not recover the full amount of their original investment.
            </p>
          </div>
          <div class="flex items-start gap-4">
            <svg class="w-5 h-5 text-gold-accent shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <p data-i18n
               data-hy="&#1363;&#1377;&#1391; &#1398;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;&#1377;&#1397;&#1387;&#1398; &#1411;&#1400;&#1398;&#1380;&#1381;&#1408;&#1384; &#1400;&#1410;&#1398;&#1381;&#1398; &#1405;&#1377;&#1392;&#1396;&#1377;&#1398;&#1377;&#1411;&#1377;&#1391; &#1387;&#1408;&#1377;&#1409;&#1406;&#1377;&#1390;&#1377;&#1391;&#1377;&#1398;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;&#1417;"
               data-en="Closed-end fund investments are inherently illiquid. Fund units are not traded on any exchange and redemption is subject to the terms and conditions set forth in each fund's prospectus. Investors should be prepared to hold their investment for the duration of the fund's term.">
              Closed-end fund investments are inherently illiquid. Fund units are not traded on any exchange and redemption is subject to the terms and conditions set forth in each fund's prospectus. Investors should be prepared to hold their investment for the duration of the fund's term.
            </p>
          </div>
          <div class="flex items-start gap-4">
            <svg class="w-5 h-5 text-gold-accent shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <p data-i18n
               data-hy="&#1357;&#1400;&#1410;&#1397;&#1398; &#1391;&#1377;&#1397;&#1412;&#1384; &#1401;&#1387; &#1392;&#1377;&#1398;&#1380;&#1387;&#1405;&#1377;&#1398;&#1400;&#1410;&#1396; &#1398;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;&#1377;&#1397;&#1387;&#1398; &#1389;&#1400;&#1408;&#1392;&#1400;&#1410;&#1408;&#1380;&#1417;"
               data-en="This website does not constitute an offer, solicitation, or recommendation to purchase or sell any fund units or other financial instruments. Any investment decision should be made solely on the basis of the relevant fund's offering documents and in consultation with appropriate legal, tax, and financial advisors.">
              This website does not constitute an offer, solicitation, or recommendation to purchase or sell any fund units or other financial instruments. Any investment decision should be made solely on the basis of the relevant fund's offering documents and in consultation with appropriate legal, tax, and financial advisors.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

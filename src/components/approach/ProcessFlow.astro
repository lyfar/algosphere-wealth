---
// Four-Stage Investment Process Flow
import SectionHeader from '../SectionHeader.astro';
---
<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] ambient-blob bg-gold-400"></div>

    <div class="section-inner max-w-[1200px] mx-auto px-6 lg:px-20 relative z-10">
      <div class="text-center mb-16 lg:mb-24">
        <SectionHeader label="Our Process" labelHy="&#1348;&#1381;&#1408; &#1331;&#1400;&#1408;&#1390;&#1384;&#1398;&#1385;&#1377;&#1409;&#1384;" centered>
          <h2 class="font-heading text-3xl sm:text-4xl lg:text-[3rem] text-text-primary font-semibold leading-[1.1]">
            <span data-i18n data-hy="&#1364;&#1377;&#1404;&#1377;&#1405;&#1407;&#1387;&#1395;&#1377;&#1398; <span class='text-gold-gradient'>&#1350;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;&#1377;&#1397;&#1387;&#1398; &#1331;&#1400;&#1408;&#1390;&#1384;&#1398;&#1385;&#1377;&#1409;</span>" data-en="Four-Stage <span class='text-gold-gradient'>Investment Process</span>">Four-Stage <span class="text-gold-gradient">Investment Process</span></span>
          </h2>
        </SectionHeader>
      </div>

      <!-- Process Flow -->
      <div class="grid md:grid-cols-4 gap-6 lg:gap-4">

        <!-- Stage 1: Sourcing -->
        <div class="gs-reveal-scale relative">
          <div class="glass-card p-8 lg:p-8 text-center h-full">
            <!-- Step number -->
            <div class="w-12 h-12 mx-auto mb-6 border border-gold-400/30 rounded-full flex items-center justify-center">
              <span class="text-gold-gradient font-heading text-xl font-semibold">01</span>
            </div>
            <h3 class="font-heading text-xl text-card-title font-semibold mb-4" data-i18n data-hy="&#1329;&#1394;&#1378;&#1397;&#1400;&#1410;&#1408;&#1387; &#1344;&#1377;&#1397;&#1407;&#1398;&#1377;&#1378;&#1381;&#1408;&#1400;&#1410;&#1396;" data-en="Sourcing">Sourcing</h3>
            <p class="text-card-body-muted text-[14px] font-light leading-[1.75]" data-i18n
               data-hy="&#1344;&#1398;&#1377;&#1408;&#1377;&#1406;&#1400;&#1408;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;&#1398;&#1381;&#1408;&#1387; &#1392;&#1377;&#1397;&#1407;&#1398;&#1377;&#1378;&#1381;&#1408;&#1400;&#1410;&#1396;&#1417;"
               data-en="Systematic identification of opportunities through proprietary screening, local networks, and deep market analysis. We focus on asset classes where Armenia offers a genuine competitive advantage.">
              Systematic identification of opportunities through proprietary screening, local networks, and deep market analysis. We focus on asset classes where Armenia offers a genuine competitive advantage.
            </p>
          </div>
          <!-- Arrow connector (hidden on mobile) -->
          <div class="hidden md:block absolute top-1/2 -right-4 lg:-right-2 transform -translate-y-1/2 z-20">
            <svg class="w-6 h-6 text-gold-400/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          </div>
        </div>

        <!-- Stage 2: Diligence -->
        <div class="gs-reveal-scale relative">
          <div class="glass-card p-8 lg:p-8 text-center h-full">
            <div class="w-12 h-12 mx-auto mb-6 border border-gold-400/30 rounded-full flex items-center justify-center">
              <span class="text-gold-gradient font-heading text-xl font-semibold">02</span>
            </div>
            <h3 class="font-heading text-xl text-card-title font-semibold mb-4" data-i18n data-hy="&#1358;&#1381;&#1408;&#1388;&#1400;&#1410;&#1390;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;" data-en="Diligence">Diligence</h3>
            <p class="text-card-body-muted text-[14px] font-light leading-[1.75]" data-i18n
               data-hy="&#1341;&#1400;&#1408;&#1384; &#1406;&#1381;&#1408;&#1388;&#1400;&#1410;&#1390;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;&#1417;"
               data-en="Multi-layered due diligence combining quantitative modeling, on-the-ground research, legal review, and independent third-party validation. No investment proceeds without unanimous committee approval.">
              Multi-layered due diligence combining quantitative modeling, on-the-ground research, legal review, and independent third-party validation. No investment proceeds without unanimous committee approval.
            </p>
          </div>
          <div class="hidden md:block absolute top-1/2 -right-4 lg:-right-2 transform -translate-y-1/2 z-20">
            <svg class="w-6 h-6 text-gold-400/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          </div>
        </div>

        <!-- Stage 3: Execution -->
        <div class="gs-reveal-scale relative">
          <div class="glass-card p-8 lg:p-8 text-center h-full">
            <div class="w-12 h-12 mx-auto mb-6 border border-gold-400/30 rounded-full flex items-center justify-center">
              <span class="text-gold-gradient font-heading text-xl font-semibold">03</span>
            </div>
            <h3 class="font-heading text-xl text-card-title font-semibold mb-4" data-i18n data-hy="&#1339;&#1408;&#1377;&#1391;&#1377;&#1398;&#1377;&#1409;&#1400;&#1410;&#1396;" data-en="Execution">Execution</h3>
            <p class="text-card-body-muted text-[14px] font-light leading-[1.75]" data-i18n
               data-hy="&#1350;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;&#1398;&#1381;&#1408;&#1387; &#1387;&#1408;&#1377;&#1391;&#1377;&#1398;&#1377;&#1409;&#1400;&#1410;&#1396;&#1417;"
               data-en="Precise capital deployment with pre-defined entry criteria, position sizing, and risk parameters. Our execution framework minimizes market impact while maximizing structural protection for investors.">
              Precise capital deployment with pre-defined entry criteria, position sizing, and risk parameters. Our execution framework minimizes market impact while maximizing structural protection for investors.
            </p>
          </div>
          <div class="hidden md:block absolute top-1/2 -right-4 lg:-right-2 transform -translate-y-1/2 z-20">
            <svg class="w-6 h-6 text-gold-400/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          </div>
        </div>

        <!-- Stage 4: Monitoring -->
        <div class="gs-reveal-scale">
          <div class="glass-card p-8 lg:p-8 text-center h-full">
            <div class="w-12 h-12 mx-auto mb-6 border border-gold-400/30 rounded-full flex items-center justify-center">
              <span class="text-gold-gradient font-heading text-xl font-semibold">04</span>
            </div>
            <h3 class="font-heading text-xl text-card-title font-semibold mb-4" data-i18n data-hy="&#1348;&#1400;&#1398;&#1387;&#1407;&#1400;&#1408;&#1387;&#1398;&#1379;" data-en="Monitoring">Monitoring</h3>
            <p class="text-card-body-muted text-[14px] font-light leading-[1.75]" data-i18n
               data-hy="&#1348;&#1399;&#1407;&#1377;&#1391;&#1377;&#1398; &#1396;&#1400;&#1398;&#1387;&#1407;&#1400;&#1408;&#1387;&#1398;&#1379;&#1417;"
               data-en="Continuous portfolio monitoring with automated risk alerts, regular rebalancing triggers, and systematic performance attribution. We maintain active dialogue with investee management teams to protect and enhance value.">
              Continuous portfolio monitoring with automated risk alerts, regular rebalancing triggers, and systematic performance attribution. We maintain active dialogue with investee management teams to protect and enhance value.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

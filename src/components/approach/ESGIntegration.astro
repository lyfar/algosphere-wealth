---
// ESG Integration / Responsible Investing
import SectionHeader from '../SectionHeader.astro';
---
<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
    <div class="absolute top-0 right-1/4 w-[400px] h-[400px] ambient-blob bg-gold-400"></div>

    <div class="section-inner max-w-[1200px] mx-auto px-6 lg:px-20 relative z-10">
      <div class="text-center mb-16">
        <SectionHeader label="Responsible Investing" labelHy="&#1354;&#1377;&#1407;&#1377;&#1405;&#1389;&#1377;&#1398;&#1377;&#1407;&#1400;&#1410; &#1350;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;" centered>
          <h2 class="font-heading text-3xl sm:text-4xl lg:text-[3rem] text-text-primary font-semibold leading-[1.1]">
            <span data-i18n data-hy="ESG <span class='text-gold-gradient'>&#1339;&#1398;&#1407;&#1381;&#1379;&#1408;&#1377;&#1409;&#1387;&#1377;</span>" data-en="ESG <span class='text-gold-gradient'>Integration</span>">ESG <span class="text-gold-gradient">Integration</span></span>
          </h2>
        </SectionHeader>
      </div>

      <div class="gs-reveal max-w-[800px] mx-auto">
        <div class="glass-card p-10 lg:p-14">
          <div class="space-y-6 text-[16px] text-card-body font-light leading-[1.8]">
            <p data-i18n
               data-hy="Algosphere-&#1400;&#1410;&#1396; &#1396;&#1381;&#1398;&#1412; &#1392;&#1377;&#1396;&#1400;&#1382;&#1406;&#1377;&#1390; &#1381;&#1398;&#1412;, &#1400;&#1408; &#1399;&#1408;&#1403;&#1377;&#1391;&#1377;&#1397;&#1412;&#1387;, &#1405;&#1400;&#1409;&#1387;&#1377;&#1388;&#1377;&#1391;&#1377;&#1398; &#1415; &#1391;&#1377;&#1404;&#1377;&#1406;&#1377;&#1408;&#1396;&#1377;&#1398; &#1379;&#1400;&#1408;&#1390;&#1400;&#1398;&#1398;&#1381;&#1408;&#1384; (ESG) &#1383;&#1377;&#1391;&#1377;&#1398;&#1400;&#1408;&#1381;&#1398; &#1377;&#1382;&#1380;&#1400;&#1410;&#1396; &#1381;&#1398; &#1381;&#1408;&#1391;&#1377;&#1408;&#1377;&#1386;&#1377;&#1396;&#1391;&#1381;&#1407; &#1398;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;&#1377;&#1397;&#1387;&#1398; &#1377;&#1408;&#1380;&#1397;&#1400;&#1410;&#1398;&#1412;&#1398;&#1381;&#1408;&#1387; &#1406;&#1408;&#1377;&#1417;"
               data-en="At Algosphere, we believe that environmental, social, and governance (ESG) factors are material to long-term investment performance. We integrate ESG considerations into our due diligence process and ongoing portfolio monitoring — not as a separate overlay, but as an intrinsic component of fundamental analysis.">
              At Algosphere, we believe that environmental, social, and governance (ESG) factors are material to long-term investment performance. We integrate ESG considerations into our due diligence process and ongoing portfolio monitoring — not as a separate overlay, but as an intrinsic component of fundamental analysis.
            </p>
            <p data-i18n
               data-hy="&#1352;&#1408;&#1402;&#1381;&#1405; &#1344;&#1377;&#1397;&#1377;&#1405;&#1407;&#1377;&#1398;&#1387; &#1407;&#1398;&#1407;&#1381;&#1405;&#1400;&#1410;&#1385;&#1397;&#1377;&#1398; &#1382;&#1377;&#1408;&#1379;&#1377;&#1409;&#1396;&#1377;&#1398;&#1384; &#1398;&#1402;&#1377;&#1405;&#1407;&#1400;&#1394; &#1398;&#1381;&#1408;&#1380;&#1408;&#1400;&#1394;, &#1396;&#1381;&#1398;&#1412; &#1393;&#1379;&#1407;&#1400;&#1410;&#1396; &#1381;&#1398;&#1412; &#1377;&#1403;&#1377;&#1391;&#1409;&#1381;&#1388; &#1392;&#1377;&#1397;&#1391;&#1377;&#1391;&#1377;&#1398; &#1392;&#1377;&#1396;&#1377;&#1397;&#1398;&#1412;&#1398;&#1381;&#1408;&#1387; &#1391;&#1377;&#1397;&#1400;&#1410;&#1398; &#1382;&#1377;&#1408;&#1379;&#1377;&#1409;&#1400;&#1410;&#1396;&#1384;&#1417;"
               data-en="As an investor committed to Armenia's economic development, we seek to support companies and projects that contribute to sustainable community growth — from technology-driven job creation and infrastructure modernization to environmental stewardship and transparent corporate governance practices.">
              As an investor committed to Armenia's economic development, we seek to support companies and projects that contribute to sustainable community growth — from technology-driven job creation and infrastructure modernization to environmental stewardship and transparent corporate governance practices.
            </p>
          </div>

          <div class="grid sm:grid-cols-3 gap-6 mt-10 pt-8 border-t border-white/[0.06]">
            <div class="text-center">
              <div class="w-10 h-10 mx-auto mb-3 border border-gold-400/25 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
                </svg>
              </div>
              <p class="text-text-primary text-[14px] font-medium" data-i18n data-hy="&#1351;&#1408;&#1403;&#1377;&#1391;&#1377;&#1397;&#1412;" data-en="Environmental">Environmental</p>
              <p class="text-card-body-muted text-[12px] font-light mt-1" data-i18n data-hy="&#1343;&#1377;&#1397;&#1400;&#1410;&#1398; &#1382;&#1377;&#1408;&#1379;&#1377;&#1409;&#1400;&#1410;&#1396;" data-en="Sustainable growth">Sustainable growth</p>
            </div>
            <div class="text-center">
              <div class="w-10 h-10 mx-auto mb-3 border border-gold-400/25 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
                </svg>
              </div>
              <p class="text-text-primary text-[14px] font-medium" data-i18n data-hy="&#1357;&#1400;&#1409;&#1387;&#1377;&#1388;&#1377;&#1391;&#1377;&#1398;" data-en="Social">Social</p>
              <p class="text-card-body-muted text-[12px] font-light mt-1" data-i18n data-hy="&#1344;&#1377;&#1396;&#1377;&#1397;&#1398;&#1412;&#1387; &#1382;&#1377;&#1408;&#1379;&#1377;&#1409;&#1400;&#1410;&#1396;" data-en="Community impact">Community impact</p>
            </div>
            <div class="text-center">
              <div class="w-10 h-10 mx-auto mb-3 border border-gold-400/25 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
                </svg>
              </div>
              <p class="text-text-primary text-[14px] font-medium" data-i18n data-hy="&#1343;&#1377;&#1404;&#1377;&#1406;&#1377;&#1408;&#1400;&#1410;&#1396;" data-en="Governance">Governance</p>
              <p class="text-card-body-muted text-[12px] font-light mt-1" data-i18n data-hy="&#1337;&#1377;&#1411;&#1377;&#1398;&#1409;&#1387;&#1391; &#1379;&#1400;&#1408;&#1390;&#1384;&#1398;&#1385;&#1377;&#1409;" data-en="Transparent practices">Transparent practices</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

---
// Risk Management Framework
import SectionHeader from '../SectionHeader.astro';
---
<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
    <div class="absolute bottom-0 left-1/3 w-[500px] h-[500px] ambient-blob bg-gold-400"></div>

    <div class="section-inner max-w-[1200px] mx-auto px-6 lg:px-20 relative z-10">
      <SectionHeader label="Risk Management" labelHy="&#1356;&#1387;&#1405;&#1391;&#1381;&#1408;&#1387; &#1343;&#1377;&#1404;&#1377;&#1406;&#1377;&#1408;&#1400;&#1410;&#1396;" />

      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 mt-12">
        <div class="gs-reveal">
          <h2 class="font-heading text-2xl sm:text-3xl lg:text-4xl text-text-primary font-semibold mb-8 leading-[1.15]">
            <span data-i18n data-hy="&#1356;&#1387;&#1405;&#1391;&#1381;&#1408;&#1387; <span class='text-gold-gradient'>&#1344;&#1377;&#1396;&#1377;&#1391;&#1377;&#1408;&#1379;</span>" data-en="Our Risk <span class='text-gold-gradient'>Framework</span>">Our Risk <span class="text-gold-gradient">Framework</span></span>
          </h2>
          <div class="space-y-6 text-[16px] text-card-body font-light leading-[1.8]">
            <p data-i18n
               data-hy="&#1356;&#1387;&#1405;&#1391;&#1381;&#1408;&#1387; &#1391;&#1377;&#1404;&#1377;&#1406;&#1377;&#1408;&#1400;&#1410;&#1396;&#1384; &#1396;&#1381;&#1408; &#1379;&#1400;&#1408;&#1390;&#1400;&#1410;&#1398;&#1381;&#1400;&#1410;&#1385;&#1397;&#1377;&#1398; &#1392;&#1387;&#1396;&#1412;&#1400;&#1410;&#1396; &#1383;&#1417;"
               data-en="Risk management is not a separate function at Algosphere — it is woven into every layer of our investment process. We believe that superior risk management is the foundation of superior returns.">
              Risk management is not a separate function at Algosphere — it is woven into every layer of our investment process. We believe that superior risk management is the foundation of superior returns.
            </p>
            <p data-i18n
               data-hy="&#1348;&#1381;&#1408; &#1396;&#1400;&#1407;&#1381;&#1409;&#1400;&#1410;&#1396;&#1384; &#1384;&#1398;&#1380;&#1379;&#1408;&#1391;&#1400;&#1410;&#1396; &#1383; &#1404;&#1387;&#1405;&#1391;&#1381;&#1408;&#1387; &#1378;&#1377;&#1382;&#1396;&#1377;&#1385;&#1387;&#1406; &#1407;&#1381;&#1405;&#1377;&#1391;&#1398;&#1381;&#1408;&#1417;"
               data-en="Our framework encompasses market risk, credit risk, liquidity risk, operational risk, and concentration risk — each with defined limits, monitoring protocols, and escalation procedures.">
              Our framework encompasses market risk, credit risk, liquidity risk, operational risk, and concentration risk — each with defined limits, monitoring protocols, and escalation procedures.
            </p>
          </div>
        </div>

        <div class="gs-reveal-right space-y-5">
          <!-- Risk pillars -->
          <div class="glass-card p-6 flex items-start gap-4">
            <div class="w-10 h-10 border border-glass-border rounded-xl flex items-center justify-center bg-gold-400/[0.03] shrink-0">
              <svg class="w-5 h-5 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
              </svg>
            </div>
            <div>
              <p class="text-text-primary text-[15px] font-medium mb-1" data-i18n data-hy="&#1354;&#1400;&#1382;&#1387;&#1409;&#1387;&#1377;&#1397;&#1387; &#1357;&#1377;&#1392;&#1396;&#1377;&#1398;&#1377;&#1411;&#1377;&#1391;&#1400;&#1410;&#1396;&#1398;&#1381;&#1408;" data-en="Position Limits">Position Limits</p>
              <p class="text-card-body-muted text-[14px] font-light leading-relaxed" data-i18n
                 data-hy="&#1350;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;&#1398;&#1381;&#1408;&#1387; &#1405;&#1377;&#1392;&#1396;&#1377;&#1398;&#1377;&#1411;&#1377;&#1391;&#1396;&#1377;&#1398; &#1391;&#1377;&#1398;&#1400;&#1398;&#1398;&#1381;&#1408;"
                 data-en="Maximum single-position and sector concentration limits enforced systematically across all portfolios">Maximum single-position and sector concentration limits enforced systematically across all portfolios</p>
            </div>
          </div>

          <div class="glass-card p-6 flex items-start gap-4">
            <div class="w-10 h-10 border border-glass-border rounded-xl flex items-center justify-center bg-gold-400/[0.03] shrink-0">
              <svg class="w-5 h-5 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.249-8.25-3.286zm0 13.036h.008v.008H12v-.008z" />
              </svg>
            </div>
            <div>
              <p class="text-text-primary text-[15px] font-medium mb-1" data-i18n data-hy="&#1357;&#1385;&#1408;&#1381;&#1405;-&#1385;&#1381;&#1405;&#1407;&#1387;&#1398;&#1379;" data-en="Stress Testing">Stress Testing</p>
              <p class="text-card-body-muted text-[14px] font-light leading-relaxed" data-i18n
                 data-hy="&#1354;&#1400;&#1408;&#1407;&#1411;&#1381;&#1388;&#1387; &#1405;&#1385;&#1408;&#1381;&#1405;-&#1385;&#1381;&#1405;&#1407;&#1387;&#1398;&#1379;&#1417;"
                 data-en="Regular scenario analysis and stress testing against historical and hypothetical market disruptions">Regular scenario analysis and stress testing against historical and hypothetical market disruptions</p>
            </div>
          </div>

          <div class="glass-card p-6 flex items-start gap-4">
            <div class="w-10 h-10 border border-glass-border rounded-xl flex items-center justify-center bg-gold-400/[0.03] shrink-0">
              <svg class="w-5 h-5 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
              </svg>
            </div>
            <div>
              <p class="text-text-primary text-[15px] font-medium mb-1" data-i18n data-hy="&#1339;&#1408;&#1377;&#1409;&#1406;&#1377;&#1390;&#1377;&#1397;&#1387;&#1398; &#1329;&#1398;&#1406;&#1407;&#1377;&#1398;&#1379;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;" data-en="Operational Security">Operational Security</p>
              <p class="text-card-body-muted text-[14px] font-light leading-relaxed" data-i18n
                 data-hy="&#1331;&#1400;&#1408;&#1390;&#1377;&#1404;&#1398;&#1377;&#1391;&#1377;&#1398; &#1377;&#1398;&#1406;&#1407;&#1377;&#1398;&#1379;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;&#1417;"
                 data-en="Segregated custody, independent fund administration, and multi-signatory authorization for all capital movements">Segregated custody, independent fund administration, and multi-signatory authorization for all capital movements</p>
            </div>
          </div>

          <div class="glass-card p-6 flex items-start gap-4">
            <div class="w-10 h-10 border border-glass-border rounded-xl flex items-center justify-center bg-gold-400/[0.03] shrink-0">
              <svg class="w-5 h-5 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3" />
              </svg>
            </div>
            <div>
              <p class="text-text-primary text-[15px] font-medium mb-1" data-i18n data-hy="&#1339;&#1408;&#1377;&#1409;&#1406;&#1377;&#1390;&#1377;&#1391;&#1377;&#1398;&#1400;&#1410;&#1385;&#1397;&#1400;&#1410;&#1398;" data-en="Liquidity Management">Liquidity Management</p>
              <p class="text-card-body-muted text-[14px] font-light leading-relaxed" data-i18n
                 data-hy="&#1339;&#1408;&#1377;&#1409;&#1406;&#1377;&#1390;&#1377;&#1391;&#1377;&#1398;&#1400;&#1410;&#1385;&#1397;&#1377;&#1398; &#1391;&#1377;&#1404;&#1377;&#1406;&#1377;&#1408;&#1400;&#1410;&#1396;&#1417;"
                 data-en="Structured liquidity reserves and redemption frameworks designed to meet obligations while maintaining investment discipline">Structured liquidity reserves and redemption frameworks designed to meet obligations while maintaining investment discipline</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

---
// Animated Key Metrics Bar — 2024 / CBA / Closed / Qualified
---
<section class="relative py-16 sm:py-20 overflow-hidden" style="border-top: 1px solid rgba(255,255,255,0.03); border-bottom: 1px solid rgba(255,255,255,0.03);">
  <div class="absolute inset-0 hero-radial-glow"></div>
  <div class="max-w-[1200px] mx-auto px-6 lg:px-20 relative z-10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12">
      <div class="text-center gs-reveal-scale">
        <p class="font-heading text-3xl sm:text-4xl lg:text-5xl font-semibold mb-3">
          <span class="text-gold-gradient">2024</span>
        </p>
        <p class="text-[0.68rem] tracking-[0.18em] uppercase text-card-body-muted font-medium" data-i18n
           data-hy="&#1344;&#1387;&#1396;&#1398;&#1377;&#1380;&#1408;&#1406;&#1377;&#1390;"
           data-en="Established"
           data-ru="Основана"
           data-fr="Fondée"
           data-ar="تأسست">Established</p>
      </div>
      <div class="text-center gs-reveal-scale">
        <div class="flex items-center justify-center gap-2 mb-3">
          <svg class="w-6 h-6 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
          <p class="font-heading text-3xl sm:text-4xl lg:text-5xl font-semibold text-gold-gradient" data-i18n
             data-hy="&#1343;&#1330;"
             data-en="CBA"
             data-ru="ЦБ"
             data-fr="BCA"
             data-ar="م.أ">CBA</p>
        </div>
        <p class="text-[0.68rem] tracking-[0.18em] uppercase text-card-body-muted font-medium" data-i18n
           data-hy="&#1340;&#1387;&#1409;&#1381;&#1398;&#1382;&#1377;&#1406;&#1400;&#1408;&#1406;&#1377;&#1390;"
           data-en="Licensed"
           data-ru="Лицензирована"
           data-fr="Agréée"
           data-ar="مرخصة">Licensed</p>
      </div>
      <div class="text-center gs-reveal-scale">
        <p class="font-heading text-3xl sm:text-4xl lg:text-5xl font-semibold mb-3">
          <span class="text-gold-gradient" data-i18n
                data-hy="&#1363;&#1377;&#1391;"
                data-en="Closed"
                data-ru="Закрытые"
                data-fr="Fermés"
                data-ar="مغلقة">Closed</span>
        </p>
        <p class="text-[0.68rem] tracking-[0.18em] uppercase text-card-body-muted font-medium" data-i18n
           data-hy="&#1350;&#1381;&#1408;&#1380;&#1408;&#1400;&#1410;&#1396;&#1377;&#1397;&#1387;&#1398; &#1366;&#1400;&#1398;&#1380;&#1381;&#1408;"
           data-en="End Funds"
           data-ru="Фонды"
           data-fr="Fonds"
           data-ar="صناديق">End Funds</p>
      </div>
      <div class="text-center gs-reveal-scale">
        <p class="font-heading text-3xl sm:text-4xl lg:text-5xl font-semibold mb-3">
          <span class="text-gold-gradient" data-i18n
                data-hy="&#1352;&#1408;&#1377;&#1391;&#1377;&#1406;&#1400;&#1408;&#1406;&#1377;&#1390;"
                data-en="Qualified"
                data-ru="Избранные"
                data-fr="Qualifiés"
                data-ar="مؤهلون">Qualified</span>
        </p>
        <p class="text-[0.68rem] tracking-[0.18em] uppercase text-card-body-muted font-medium" data-i18n
           data-hy="&#1348;&#1387;&#1377;&#1397;&#1398; &#1350;&#1381;&#1408;&#1380;&#1408;&#1400;&#1394;&#1398;&#1381;&#1408;"
           data-en="Investors Only"
           data-ru="Инвесторы"
           data-fr="Investisseurs uniquement"
           data-ar="مستثمرون فقط">Investors Only</p>
      </div>
    </div>
  </div>
</section>
